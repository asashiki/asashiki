---
import PageHeader from "@components/PageHeader.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { Icon } from "astro-icon/components";

type ProjectItem = {
	name: string;
	desc: string;
	icon: string;
	liveUrl?: string;
	repoUrl?: string;
	tag?: string;
	status?: "live" | "repo" | "planned";
};

type ProjectLane = {
	key: string;
	label: string;
	kicker: string;
	icon: string;
	lead: string;
	meta: string;
	items: ProjectItem[];
};

const githubUrl = "https://github.com/asashiki";
const showUrl = "https://show.asashiki.com/";

const lanes: ProjectLane[] = [
	{
		key: "aitools",
		label: "AI Tools",
		kicker: "aitools",
		icon: "material-symbols:device-hub-rounded",
		lead: "MCP 相关项目是主线：把表情、语音、音乐、抽选、设备时间线这些工具放进对话里。",
		meta: "MCP Apps / Gateway / Personal data",
		items: [
			{
				name: "mcp-switch",
				desc: "自托管 MCP 聚合网关，把本地 stdio 与远程 HTTP 服务收束到一个 OAuth 入口。",
				icon: "material-symbols:hub-outline",
				liveUrl: "https://switch.asashiki.com",
				repoUrl: "https://github.com/asashiki/mcp-switch",
				tag: "代表项目",
				status: "live",
			},
			{
				name: "MCP Apps 展示站",
				desc: "集中展示 sticker、voice、music、reel-rando、device-timeline 等对话内工具。",
				icon: "material-symbols:gallery-thumbnail-outline-rounded",
				liveUrl: showUrl,
				repoUrl: githubUrl,
				tag: "项目索引",
				status: "live",
			},
			{
				name: "device-timeline-mcp",
				desc: "跨设备时间线上传与 MCP 接入，为状态页、健康记录和 Agent 查询提供数据底座。",
				icon: "material-symbols:devices-other-outline-rounded",
				repoUrl: "https://github.com/asashiki/device-timeline-mcp",
				tag: "data timeline",
				status: "repo",
			},
		],
	},
	{
		key: "vibeweb",
		label: "Vibe Web",
		kicker: "vibeweb",
		icon: "material-symbols:sports-esports-outline-rounded",
		lead: "随手 vibe 出来的页面和玩具，轻量、可玩，更多是把一个点子快速做成可打开的网页。",
		meta: "game pages / tiny tools",
		items: [
			{
				name: "Hana",
				desc: "一个很轻的网页音游玩具，偏实验和手感测试。",
				icon: "material-symbols:music-note-rounded",
				liveUrl: "https://hana.714.fyi/",
				tag: "音游",
				status: "live",
			},
			{
				name: "Danmaku Design",
				desc: "弹幕设计小游戏，用简单规则玩弹幕的节奏、密度和形状。",
				icon: "material-symbols:movie-edit-outline-rounded",
				liveUrl: "https://danmaku.asashiki.com/",
				tag: "弹幕玩具",
				status: "live",
			},
			{
				name: "死了没 · BPM",
				desc: "一句话 vibe 小页面，属于工具页那一侧，保留一点随手做的轻松感。",
				icon: "material-symbols:favorite-outline-rounded",
				liveUrl: "https://bpm.asashiki.com",
				tag: "工具页",
				status: "live",
			},
		],
	},
	{
		key: "agent",
		label: "Agent",
		kicker: "agent",
		icon: "material-symbols:smart-toy-outline-rounded",
		lead: "面向 Agent 工作流的项目，目前更像预留出来的方向：先把仓库和入口放好。",
		meta: "agent workflow / media automation",
		items: [
			{
				name: "X2Video",
				desc: "面向 X / Twitter 内容到视频的 Agent 项目，仓库已创建，后续再展开。",
				icon: "material-symbols:auto-awesome-outline-rounded",
				repoUrl: "https://github.com/asashiki/X2Video",
				tag: "待展开",
				status: "planned",
			},
		],
	},
	{
		key: "others",
		label: "Others",
		kicker: "others",
		icon: "material-symbols:extension-outline-rounded",
		lead: "不完全属于 MCP 或 vibeweb 的实用项目、设计系统和归档工具，作为旁支收纳。",
		meta: "utility / design / archive",
		items: [
			{
				name: "nico-danmaku-api",
				desc: "自托管 NicoNico 日语弹幕代理，让播放器通过弹弹play API 形态加载 Nico 评论。",
				icon: "material-symbols:api-rounded",
				repoUrl: "https://github.com/asashiki/nico-danmaku-api",
				tag: "弹幕 API",
				status: "repo",
			},
			{
				name: "asashiki-design",
				desc: "浅仪式的设计系统、视觉规范和 tokens，现在这批页面也沿用这套语言。",
				icon: "material-symbols:design-services-outline-rounded",
				repoUrl: "https://github.com/asashiki/asashiki-design",
				tag: "design system",
				status: "repo",
			},
			{
				name: "全部仓库",
				desc: "GitHub 账号 asashiki 下的完整项目列表，零散项目和旧实验都从这里进入。",
				icon: "fa6-brands:github",
				repoUrl: githubUrl,
				tag: "GitHub",
				status: "repo",
			},
		],
	},
];

function host(url?: string) {
	if (!url) return "";
	try {
		return new URL(url).hostname.replace(/^www\./, "");
	} catch {
		return "";
	}
}

function statusLabel(status?: ProjectItem["status"]) {
	if (status === "live") return "Live";
	if (status === "planned") return "Planned";
	return "Repo";
}
---

<MainGridLayout title="探索" description="Asashiki 的项目方向索引">
	<div class="xp-shell flex w-full max-w-[100vw] min-w-0 rounded-[var(--radius-large)] overflow-hidden relative mb-4">
		<div class="card-base z-10 px-6 md:px-9 py-7 relative w-full max-w-full min-w-0 overflow-hidden">
			<PageHeader
				kicker="Explore"
				title="探索"
				lead="按项目方向整理：AI tools、vibeweb、agent，以及其他实用旁支。"
			/>

			<section class="xp-overview onload-animation" style="animation-delay: calc(var(--content-delay) + 40ms);" aria-label="项目方向总览">
				<div class="xp-overview-copy">
					<span class="xp-eyebrow">asashiki / github</span>
					<h2>把项目先按方向放好。</h2>
					<p>
						主要重心是 MCP 与对话内工具；vibeweb 放玩具和小页面；Agent 方向先留入口；其他项目归到旁支里。
					</p>
				</div>
				<div class="xp-overview-actions">
					<a href={showUrl} target="_blank" rel="noopener" class="xp-action">
						<Icon name="material-symbols:gallery-thumbnail-outline-rounded" />
						<span>展示站</span>
					</a>
					<a href={githubUrl} target="_blank" rel="noopener" class="xp-action">
						<Icon name="fa6-brands:github" />
						<span>GitHub</span>
					</a>
				</div>
			</section>

			<nav class="xp-index onload-animation" style="animation-delay: calc(var(--content-delay) + 70ms);" aria-label="项目方向">
				{lanes.map((lane) => (
					<a href={`#${lane.key}`} class="xp-index-item">
						<Icon name={lane.icon} />
						<span>{lane.kicker}</span>
					</a>
				))}
			</nav>

			<div class="xp-lanes">
				{lanes.map((lane, index) => (
					<section id={lane.key} class="xp-lane onload-animation" style={`animation-delay: calc(var(--content-delay) + ${110 + index * 35}ms);`}>
						<header class="xp-lane-head">
							<div class="xp-lane-title">
								<span class="xp-lane-icon" aria-hidden="true">
									<Icon name={lane.icon} />
								</span>
								<div>
									<span class="xp-eyebrow">{lane.kicker}</span>
									<h2>{lane.label}</h2>
								</div>
							</div>
							<p>{lane.lead}</p>
							<span class="xp-lane-meta">{lane.meta}</span>
						</header>

						<ul class="xp-projects">
							{lane.items.map((item) => {
								const primaryUrl = item.liveUrl || item.repoUrl;
								return (
									<li>
										<a href={primaryUrl} target="_blank" rel="noopener" class:list={["xp-project", { "is-planned": item.status === "planned" }]}>
											<span class="xp-project-icon" aria-hidden="true">
												<Icon name={item.icon} />
											</span>
											<span class="xp-project-body">
												<span class="xp-project-top">
													<strong>{item.name}</strong>
													<span class:list={["xp-pill", `is-${item.status || "repo"}`]}>{statusLabel(item.status)}</span>
												</span>
												<span class="xp-project-desc">{item.desc}</span>
												<span class="xp-project-links">
													{item.tag && <span>{item.tag}</span>}
													{item.liveUrl && <span>{host(item.liveUrl)}</span>}
													{item.repoUrl && <span>github.com/asashiki</span>}
												</span>
											</span>
											<Icon name="fa6-solid:arrow-right" class="xp-arrow" />
										</a>
									</li>
								);
							})}
						</ul>
					</section>
				))}
			</div>
		</div>
	</div>
</MainGridLayout>

<style>
	.xp-eyebrow {
		color: var(--primary);
		font-size: 0.68rem;
		font-weight: 750;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}
	.xp-shell {
		box-sizing: border-box;
	}
	:global(.page-header-lead) {
		overflow-wrap: anywhere;
	}

	.xp-overview {
		min-width: 0;
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 1rem;
		align-items: end;
		padding: 1.15rem 1.2rem;
		border-radius: calc(var(--radius-large) - 0.25rem);
		border: 1px solid color-mix(in oklch, var(--primary) 20%, var(--line-divider));
		background:
			radial-gradient(105% 90% at 92% -25%, color-mix(in oklch, var(--primary) 11%, transparent) 0%, transparent 58%),
			color-mix(in oklch, var(--primary) 4%, var(--card-bg));
	}
	.xp-overview-copy {
		min-width: 0;
	}
	.xp-overview h2 {
		margin: 0.25rem 0 0;
		color: var(--deep-text);
		font-size: clamp(1.15rem, 2.4vw, 1.55rem);
		font-weight: 720;
		line-height: 1.25;
	}
	:global(:root.dark) .xp-overview h2 {
		color: rgba(255, 255, 255, 0.92);
	}
	.xp-overview p {
		margin: 0.5rem 0 0;
		max-width: 42rem;
		color: var(--content-meta-text, rgb(120 120 130));
		font-size: 0.88rem;
		line-height: 1.65;
		overflow-wrap: anywhere;
	}
	.xp-overview-actions {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 0.5rem;
	}
	.xp-action,
	.xp-index-item {
		display: inline-flex;
		align-items: center;
		gap: 0.42rem;
		border-radius: 999px;
		text-decoration: none;
		white-space: nowrap;
	}
	.xp-action {
		min-height: 2.15rem;
		padding: 0.42rem 0.78rem;
		color: var(--btn-content);
		background: var(--btn-regular-bg);
		font-size: 0.8rem;
		font-weight: 680;
		transition: background-color 180ms ease, color 180ms ease, transform 200ms cubic-bezier(0.22, 1, 0.36, 1);
	}
	.xp-action svg {
		width: 1rem;
		height: 1rem;
	}

	.xp-index {
		min-width: 0;
		max-width: 100%;
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 0.55rem;
		margin: 0.75rem 0 1.15rem;
	}
	.xp-index-item {
		justify-content: center;
		min-width: 0;
		padding: 0.52rem 0.65rem;
		border: 1px solid color-mix(in oklch, var(--line-divider) 76%, transparent);
		color: color-mix(in oklch, var(--btn-content) 72%, var(--card-bg));
		background: var(--card-bg);
		font-size: 0.74rem;
		font-weight: 760;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		transition: color 180ms ease, border-color 180ms ease, background-color 180ms ease;
	}
	.xp-index-item svg {
		width: 1rem;
		height: 1rem;
		color: var(--primary);
	}

	.xp-lanes {
		min-width: 0;
		max-width: 100%;
		display: flex;
		flex-direction: column;
		gap: 0.95rem;
	}
	.xp-lane {
		min-width: 0;
		display: grid;
		grid-template-columns: minmax(12rem, 0.85fr) minmax(0, 1.65fr);
		gap: 1rem;
		padding-top: 0.95rem;
		border-top: 1px solid color-mix(in oklch, var(--line-divider) 78%, transparent);
		scroll-margin-top: 6rem;
	}
	.xp-lane-head {
		min-width: 0;
	}
	.xp-lane-title {
		display: flex;
		align-items: flex-start;
		gap: 0.7rem;
	}
	.xp-lane-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.55rem;
		height: 2.55rem;
		border-radius: 0.7rem;
		color: var(--primary);
		background: color-mix(in oklch, var(--primary) 7%, var(--card-bg));
		border: 1px solid color-mix(in oklch, var(--primary) 15%, transparent);
	}
	.xp-lane-icon svg {
		width: 1.22rem;
		height: 1.22rem;
	}
	.xp-lane h2 {
		margin: 0.18rem 0 0;
		color: var(--deep-text);
		font-size: 1.05rem;
		font-weight: 730;
		line-height: 1.25;
	}
	:global(:root.dark) .xp-lane h2 {
		color: rgba(255, 255, 255, 0.9);
	}
	.xp-lane-head p {
		margin: 0.7rem 0 0;
		color: var(--content-meta-text, rgb(120 120 130));
		font-size: 0.82rem;
		line-height: 1.7;
		overflow-wrap: anywhere;
	}
	.xp-lane-meta {
		display: inline-flex;
		margin-top: 0.62rem;
		color: color-mix(in oklch, var(--btn-content) 52%, var(--card-bg));
		font-size: 0.68rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
	}

	.xp-projects {
		min-width: 0;
		display: grid;
		grid-template-columns: 1fr;
		gap: 0.55rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}
	.xp-project {
		min-width: 0;
		display: grid;
		grid-template-columns: auto minmax(0, 1fr) auto;
		gap: 0.78rem;
		align-items: center;
		min-height: 5.1rem;
		padding: 0.82rem 0.9rem;
		border-radius: calc(var(--radius-large) - 0.35rem);
		border: 1px solid color-mix(in oklch, var(--line-divider) 74%, transparent);
		background: var(--card-bg);
		text-decoration: none;
		transition: transform 200ms cubic-bezier(0.22, 1, 0.36, 1), border-color 180ms ease, box-shadow 200ms ease;
	}
	.xp-project.is-planned {
		border-style: dashed;
		background: color-mix(in oklch, var(--line-divider) 9%, var(--card-bg));
	}
	.xp-project-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.25rem;
		height: 2.25rem;
		border-radius: 0.65rem;
		color: var(--primary);
		background: color-mix(in oklch, var(--primary) 6%, var(--card-bg));
		border: 1px solid color-mix(in oklch, var(--primary) 12%, transparent);
	}
	.xp-project-icon svg {
		width: 1.1rem;
		height: 1.1rem;
	}
	.xp-project-body {
		min-width: 0;
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}
	.xp-project-top {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.45rem;
	}
	.xp-project-top strong {
		color: var(--deep-text);
		font-size: 0.92rem;
		font-weight: 720;
		line-height: 1.25;
	}
	:global(:root.dark) .xp-project-top strong {
		color: rgba(255, 255, 255, 0.9);
	}
	.xp-project-desc {
		color: var(--content-meta-text, rgb(120 120 130));
		font-size: 0.78rem;
		line-height: 1.58;
		overflow-wrap: anywhere;
	}
	.xp-project-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem;
		color: color-mix(in oklch, var(--btn-content) 48%, var(--card-bg));
		font-size: 0.68rem;
		font-weight: 640;
		overflow-wrap: anywhere;
	}
	.xp-project-links span + span::before {
		content: "/";
		margin-right: 0.35rem;
		color: color-mix(in oklch, var(--line-divider) 90%, transparent);
	}
	.xp-pill {
		display: inline-flex;
		align-items: center;
		min-height: 1.25rem;
		padding: 0 0.45rem;
		border-radius: 999px;
		font-size: 0.62rem;
		font-weight: 760;
		line-height: 1;
		color: var(--primary);
		background: color-mix(in oklch, var(--primary) 10%, var(--card-bg));
		border: 1px solid color-mix(in oklch, var(--primary) 16%, transparent);
	}
	.xp-pill.is-planned {
		color: var(--content-meta-text, gray);
		background: color-mix(in oklch, var(--line-divider) 14%, var(--card-bg));
		border-color: color-mix(in oklch, var(--line-divider) 72%, transparent);
	}
	.xp-arrow {
		width: 0.72rem;
		height: 0.72rem;
		color: var(--primary);
		transition: transform 180ms cubic-bezier(0.22, 1, 0.36, 1);
	}

	@media (hover: hover) and (pointer: fine) {
		.xp-action:hover {
			transform: translateY(-2px);
			background: var(--btn-regular-bg-hover);
			color: var(--primary);
		}
		.xp-index-item:hover {
			color: var(--primary);
			border-color: color-mix(in oklch, var(--primary) 24%, transparent);
			background: color-mix(in oklch, var(--primary) 5%, var(--card-bg));
		}
		.xp-project:hover {
			transform: translateY(-2px);
			border-color: color-mix(in oklch, var(--primary) 32%, transparent);
			box-shadow: 0 10px 22px -17px color-mix(in oklch, var(--primary) 34%, transparent);
		}
		.xp-project:hover .xp-arrow {
			transform: translateX(0.16rem);
		}
	}

	@media (max-width: 820px) {
		.xp-shell {
			width: min(100%, 100vw);
		}
		:global(.page-header),
		.xp-overview,
		.xp-index,
		.xp-lane,
		.xp-project {
			max-width: calc(100vw - 2.5rem);
		}
		.xp-overview {
			grid-template-columns: 1fr;
			align-items: start;
		}
		.xp-overview-actions {
			justify-content: flex-start;
		}
		.xp-index {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
		.xp-lane {
			grid-template-columns: 1fr;
			gap: 0.7rem;
		}
	}

	@media (max-width: 520px) {
		.xp-overview,
		.xp-project {
			padding: 0.85rem;
		}
		.xp-index {
			grid-template-columns: 1fr;
		}
		.xp-project {
			grid-template-columns: auto minmax(0, 1fr);
		}
		.xp-project > .xp-arrow {
			display: none;
		}
	}
</style>
