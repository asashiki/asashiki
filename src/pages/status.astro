---
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { Icon } from "astro-icon/components";
---

<MainGridLayout title="状态" description="Asashiki 的实时状态">
    <div class="flex w-full max-w-[100vw] rounded-[var(--radius-large)] overflow-hidden relative mb-4">
        <article class="card-base status-board relative w-full max-w-[100vw]" data-status-page>
            <header class="status-head onload-animation">
                <div class="status-head-copy">
                    <h1>状态</h1>
                    <p data-now-sentence>正在读取 Asashiki 的当前状态。</p>
                </div>
                <div class="status-head-actions">
                    <button class="status-refresh" type="button" data-status-refresh aria-label="刷新">
                        <Icon name="material-symbols:refresh-rounded" class="text-lg"></Icon>
                        <span>刷新</span>
                    </button>
                    <time data-updated-at>--:--</time>
                </div>
            </header>

            <!-- 设备 / 日期 切换 -->
            <div class="status-controls onload-animation" style="animation-delay: calc(var(--content-delay) + 40ms);">
                <nav class="status-chips" aria-label="设备筛选" data-device-tabs>
                    <button class="is-active" type="button">总览</button>
                </nav>
                <div class="status-date">
                    <span class="status-date-label" data-selected-date-label>今天</span>
                    <span class="status-date-meta" data-selected-date-meta>上海日界</span>
                    <div class="status-date-tabs" data-status-days></div>
                </div>
            </div>

            <div class="status-grid onload-animation" style="animation-delay: calc(var(--content-delay) + 80ms);">
                <!-- 心率 -->
                <article class="wg wg-metric wg-heart">
                    <div class="wg-top"><Icon name="material-symbols:favorite-outline-rounded" class="wg-icon"></Icon><span>心率</span></div>
                    <div class="wg-value"><strong data-health-heart-live><span class="status-sk status-sk-num"></span></strong><em>bpm</em></div>
                </article>
                <!-- 步数 -->
                <article class="wg wg-metric wg-steps">
                    <div class="wg-top"><Icon name="material-symbols:directions-walk-rounded" class="wg-icon"></Icon><span>步数</span></div>
                    <div class="wg-value"><strong data-health-steps-live><span class="status-sk status-sk-num"></span></strong><em>步</em></div>
                </article>
                <!-- 睡眠 -->
                <article class="wg wg-metric wg-sleep">
                    <div class="wg-top"><Icon name="material-symbols:bedtime-outline-rounded" class="wg-icon"></Icon><span>睡眠</span></div>
                    <div class="wg-value"><strong data-health-sleep><span class="status-sk status-sk-num"></span></strong></div>
                </article>
                <!-- 在线设备 -->
                <article class="wg wg-metric wg-online">
                    <div class="wg-top"><Icon name="material-symbols:devices-other-outline-rounded" class="wg-icon"></Icon><span>在线设备</span></div>
                    <div class="wg-value"><strong data-online-count><span class="status-sk status-sk-num"></span></strong><em>在线 / 全部</em></div>
                </article>

                <!-- 此刻 -->
                <article class="wg wg-now">
                    <div class="wg-top"><Icon name="material-symbols:bolt-rounded" class="wg-icon"></Icon><span>此刻</span><span class="wg-now-device" data-selected-device-label>总览</span></div>
                    <strong class="wg-now-desc" data-live-desc><span class="status-sk status-sk-line"></span></strong>
                    <div class="wg-chips" data-live-detail>
                        <span class="status-sk status-sk-chip"></span>
                        <span class="status-sk status-sk-chip"></span>
                    </div>
                    <!-- 当前应用（隐藏承载，供 renderNow 写入，也可展示） -->
                    <span class="wg-now-app" data-current-app hidden></span>
                </article>

                <!-- 今日应用 -->
                <article class="wg wg-apps" data-panel="activity">
                    <div class="wg-top"><Icon name="material-symbols:bar-chart-rounded" class="wg-icon"></Icon><span>今日应用</span><span class="wg-sub" data-activity-total></span></div>
                    <div class="status-app-scroll" data-app-scroll>
                        <div class="status-app-list" data-app-list></div>
                        <div class="status-skeleton-rows" aria-hidden="true">
                            <span class="status-sk status-sk-row"></span>
                            <span class="status-sk status-sk-row"></span>
                            <span class="status-sk status-sk-row"></span>
                        </div>
                        <p class="status-panel-message" data-panel-message></p>
                    </div>
                </article>

                <!-- 今日足迹（时间线） -->
                <article class="wg wg-timeline" data-panel="timeline">
                    <div class="wg-top"><Icon name="material-symbols:timeline" class="wg-icon"></Icon><span>今日足迹</span><span class="wg-sub" data-timeline-count></span></div>
                    <div class="status-timeline-scroll" data-timeline-scroll>
                        <ol class="status-timeline-list" data-timeline-list></ol>
                        <div class="status-skeleton-rows" aria-hidden="true">
                            <span class="status-sk status-sk-row"></span>
                            <span class="status-sk status-sk-row"></span>
                            <span class="status-sk status-sk-row"></span>
                            <span class="status-sk status-sk-row"></span>
                        </div>
                        <p class="status-panel-message" data-panel-message></p>
                    </div>
                </article>
            </div>

            <!-- 数据来源：低调页脚，承载 service 面板写入 -->
            <footer class="status-foot" data-panel="service">
                <span class="status-foot-dot" data-body-heading hidden></span>
                <span>数据来自 <a href="https://link.asashiki.com" target="_blank" rel="noopener">Hibi 日々</a> 设备时间线</span>
                <span class="status-foot-sep">·</span>
                <span data-api-state>连接中</span>
                <span class="status-foot-sep" data-service-heading hidden></span>
                <span class="status-foot-hidden" data-schema-state hidden></span>
                <span class="status-foot-hidden" data-core-state hidden></span>
                <span class="status-foot-hidden" data-connectors-state hidden></span>
            </footer>
        </article>
    </div>
</MainGridLayout>

<style is:global>
    /* ── 状态页 · 桌面小组件风 ─────────────────────────────────
       设计语言与时间胶囊/探索同源：站点原生卡片 + 樱粉主色点缀。
       去掉了旧版的 dashboard 细线条 / 绿色脉冲点 / 控制台英文 kicker。
       字体：本页全部走默认字体（衬线在这个页面上不合适，已退回普通字）。 */
    .status-board {
        --status-text: rgb(24 24 27);
        --status-muted: rgb(84 84 92);
        --status-faint: rgb(122 116 125);
        /* 状态页不用衬线，全走默认字体（衬线在这个页面上不合适） */
        --wg-serif: inherit;
        --wg-bg: color-mix(in oklch, var(--primary) 4%, var(--card-bg));
        --wg-line: color-mix(in oklch, var(--line-divider) 55%, transparent);
        position: relative;
        overflow: hidden;
        padding: 1.4rem 1.4rem 1.5rem;
        color: var(--status-text);
        background: var(--card-bg);
        font-size: 14px;
        line-height: 1.5;
    }
    /* 单一同源浅樱柔光，作 hero 光晕（与时间胶囊页一致） */
    .status-board::before {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(120% 78% at 90% -12%,
            color-mix(in oklch, var(--primary) 11%, transparent) 0%, transparent 60%);
        pointer-events: none;
        z-index: 0;
    }
    .status-board > * {
        position: relative;
        z-index: 1;
    }
    :root.dark .status-board {
        --status-text: rgb(240 240 242);
        --status-muted: rgb(202 202 210);
        --status-faint: rgb(162 158 170);
        --wg-bg: color-mix(in oklch, var(--primary) 7%, var(--card-bg));
        --wg-line: color-mix(in oklch, var(--line-divider) 65%, transparent);
    }

    /* ── 头部 ── */
    .status-head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1.15rem;
    }
    .status-head-copy h1 {
        margin: 0;
        font-family: var(--wg-serif);
        font-size: clamp(1.55rem, 3vw, 2.15rem);
        font-weight: 600;
        letter-spacing: -0.01em;
        line-height: 1.1;
        color: var(--status-text);
    }
    .status-head-copy p {
        margin: 0.45rem 0 0;
        max-width: 40rem;
        color: var(--status-muted);
        font-size: 0.92rem;
        line-height: 1.65;
    }
    .status-head-actions {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 0.45rem;
        flex: 0 0 auto;
    }
    .status-refresh {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.42rem 0.9rem;
        border-radius: 999px;
        color: var(--primary);
        background: var(--btn-regular-bg);
        font-weight: 650;
        font-size: 0.85rem;
        transition: transform 180ms cubic-bezier(0.22, 1, 0.36, 1);
    }
    .status-refresh.is-loading svg {
        animation: status-spin 0.9s linear infinite;
    }
    @keyframes status-spin {
        to { transform: rotate(360deg); }
    }
    .status-head-actions time {
        color: var(--status-faint);
        font-size: 0.74rem;
        font-weight: 600;
        font-variant-numeric: tabular-nums;
        font-family: var(--wg-serif);
        letter-spacing: 0.02em;
    }

    /* ── 控制条：设备 / 日期 ── */
    .status-controls {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        margin-bottom: 1.05rem;
    }
    .status-chips,
    .status-date-tabs {
        display: flex;
        flex-wrap: wrap;
        gap: 0.42rem;
    }
    .status-chips button {
        min-height: 2rem;
        padding: 0.32rem 0.8rem;
        border-radius: 999px;
        border: 1px solid transparent;
        background: var(--btn-regular-bg);
        color: var(--status-muted);
        font-size: 0.82rem;
        font-weight: 650;
        transition: transform 180ms cubic-bezier(0.22, 1, 0.36, 1), color 160ms ease, background-color 160ms ease, border-color 160ms ease;
    }
    .status-chips button.is-active {
        color: var(--primary);
        background: color-mix(in oklch, var(--primary) 12%, var(--card-bg));
        border-color: color-mix(in oklch, var(--primary) 28%, transparent);
    }
    .status-date {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-wrap: wrap;
    }
    .status-date-label {
        font-family: var(--wg-serif);
        font-size: 1rem;
        font-weight: 600;
        color: var(--status-text);
    }
    .status-date-meta {
        font-size: 0.72rem;
        color: var(--status-faint);
    }
    .status-date-tabs button {
        padding: 0.26rem 0.62rem;
        border-radius: 999px;
        background: transparent;
        color: var(--status-muted);
        font-size: 0.76rem;
        font-weight: 620;
        font-variant-numeric: tabular-nums;
        transition: color 160ms ease, background-color 160ms ease;
    }
    .status-date-tabs button.is-active {
        color: var(--primary);
        background: color-mix(in oklch, var(--primary) 12%, var(--card-bg));
    }

    /* ── 小组件网格 ── */
    .status-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 0.85rem;
    }
    .wg-now { grid-column: span 2; }
    .wg-apps { grid-column: span 2; }
    .wg-timeline { grid-column: 1 / -1; }
    @media (max-width: 900px) {
        .status-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .wg-now, .wg-apps, .wg-timeline { grid-column: 1 / -1; }
    }
    @media (max-width: 520px) {
        .status-grid { grid-template-columns: 1fr; }
        .wg-now, .wg-apps, .wg-timeline { grid-column: auto; }
    }

    .wg {
        min-width: 0;
        padding: 1.05rem 1.1rem;
        border-radius: 1rem;
        background: var(--wg-bg);
        border: 1px solid var(--wg-line);
    }
    .wg-top {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        color: var(--status-muted);
        font-size: 0.82rem;
        font-weight: 650;
    }
    .wg-top .wg-icon {
        font-size: 1.1rem;
        color: var(--primary);
        flex: 0 0 auto;
    }
    .wg-sub {
        margin-left: auto;
        color: var(--status-faint);
        font-size: 0.72rem;
        font-weight: 600;
        font-variant-numeric: tabular-nums;
    }

    /* 指标大数字卡 */
    .wg-metric {
        display: flex;
        flex-direction: column;
        gap: 0.65rem;
        min-height: 6.4rem;
    }
    .wg-value {
        display: flex;
        align-items: baseline;
        gap: 0.35rem;
        flex-wrap: wrap;
    }
    .wg-value strong {
        font-family: var(--wg-serif);
        font-size: clamp(1.7rem, 3.4vw, 2.3rem);
        font-weight: 600;
        line-height: 1;
        color: var(--status-text);
        font-variant-numeric: tabular-nums;
        letter-spacing: -0.01em;
    }
    .wg-value em {
        font-style: normal;
        font-size: 0.78rem;
        font-weight: 600;
        color: var(--status-faint);
    }
    /* 「暂无 / --」占位值：缩小、淡化，不要占大数字的位置 */
    .wg-value strong.is-na {
        font-size: 1.05rem;
        font-weight: 600;
        color: var(--status-faint);
        letter-spacing: 0;
    }
    /* 占位时把单位藏掉，避免出现「暂无 bpm」 */
    .wg-value:has(strong.is-na) em {
        display: none;
    }
    /* 在线设备：数字前一颗状态点（替代旧绿点，跟随语义 tone） */
    .wg-online .wg-value strong[data-tone] {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
    }
    .wg-online .wg-value strong[data-tone]::before {
        content: "";
        width: 0.5rem;
        height: 0.5rem;
        border-radius: 999px;
        background: var(--status-faint);
    }
    .wg-online .wg-value strong[data-tone="online"]::before {
        background: var(--success, #59b98a);
        box-shadow: 0 0 0 0.2rem color-mix(in oklch, var(--success, #59b98a) 20%, transparent);
    }

    /* 此刻 */
    .wg-now {
        display: flex;
        flex-direction: column;
        gap: 0.55rem;
    }
    .wg-now-device {
        margin-left: auto;
        padding: 0.1rem 0.5rem;
        border-radius: 999px;
        background: var(--btn-regular-bg);
        color: var(--status-faint);
        font-size: 0.7rem;
        font-weight: 650;
    }
    .wg-now-desc {
        font-size: 1.02rem;
        font-weight: 640;
        line-height: 1.5;
        color: var(--status-text);
    }
    .wg-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 0.42rem;
    }
    .wg-chips span {
        display: inline-flex;
        align-items: center;
        gap: 0.38rem;
        padding: 0.26rem 0.6rem;
        border-radius: 999px;
        color: var(--status-muted);
        background: color-mix(in oklch, var(--primary) 6%, var(--card-bg));
        border: 1px solid color-mix(in oklch, var(--primary) 12%, transparent);
        font-size: 0.78rem;
        font-weight: 620;
    }
    .wg-chips span[data-tone]::before {
        content: "";
        width: 0.44rem;
        height: 0.44rem;
        border-radius: 999px;
        background: var(--status-faint);
    }
    .wg-chips span[data-tone="online"] {
        color: var(--success, #59b98a);
        border-color: color-mix(in oklch, var(--success, #59b98a) 28%, transparent);
        background: color-mix(in oklch, var(--success, #59b98a) 8%, var(--card-bg));
    }
    .wg-chips span[data-tone="online"]::before {
        background: var(--success, #59b98a);
        box-shadow: 0 0 0 0.15rem color-mix(in oklch, var(--success, #59b98a) 22%, transparent);
    }

    /* 今日应用 */
    .status-app-scroll {
        max-height: 15.5rem;
        overflow-y: auto;
        margin-top: 0.85rem;
        scrollbar-width: thin;
    }
    .status-app-list {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }
    .status-app-row {
        display: flex;
        flex-direction: column;
        gap: 0.28rem;
    }
    .status-app-top {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 0.6rem;
    }
    .status-app-name {
        font-weight: 640;
        font-size: 0.9rem;
        color: var(--status-text);
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    .status-app-time {
        flex: 0 0 auto;
        color: var(--status-muted);
        font-size: 0.82rem;
        font-weight: 600;
        font-variant-numeric: tabular-nums;
        font-family: var(--wg-serif);
    }
    .status-app-detail {
        font-size: 0.72rem;
        color: var(--status-faint);
    }
    .status-app-track {
        height: 0.5rem;
        margin-top: 0.15rem;
        border-radius: 999px;
        background: color-mix(in oklch, var(--primary) 10%, var(--card-bg));
        overflow: hidden;
    }
    .status-app-track span {
        display: block;
        height: 100%;
        width: var(--ratio, 0%);
        border-radius: 999px;
        background: linear-gradient(90deg,
            color-mix(in oklch, var(--primary) 78%, var(--card-bg)),
            var(--primary));
    }

    /* 今日足迹（时间线） */
    .status-timeline-scroll {
        max-height: 24rem;
        overflow-y: auto;
        margin-top: 0.85rem;
        scrollbar-width: thin;
    }
    .status-timeline-list {
        display: flex;
        flex-direction: column;
        gap: 0;
        margin: 0;
        padding: 0;
        list-style: none;
    }
    .status-timeline-item {
        display: grid;
        grid-template-columns: 3.1rem minmax(0, 1fr) auto;
        gap: 0.7rem;
        align-items: baseline;
        padding: 0.6rem 0;
    }
    .status-timeline-item + .status-timeline-item {
        border-top: 1px solid color-mix(in oklch, var(--line-divider) 45%, transparent);
    }
    .status-timeline-time {
        color: var(--primary);
        font-size: 0.82rem;
        font-weight: 650;
        font-variant-numeric: tabular-nums;
        font-family: var(--wg-serif);
    }
    .status-timeline-main {
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
    }
    .status-timeline-main strong {
        font-weight: 620;
        font-size: 0.9rem;
        color: var(--status-text);
        line-height: 1.4;
    }
    .status-timeline-main span {
        font-size: 0.74rem;
        color: var(--status-faint);
    }
    .status-timeline-app {
        flex: 0 0 auto;
        align-self: center;
        padding: 0.16rem 0.5rem;
        border-radius: 999px;
        background: color-mix(in oklch, var(--primary) 8%, var(--card-bg));
        color: var(--status-muted);
        font-size: 0.7rem;
        font-weight: 620;
        white-space: nowrap;
    }
    .status-empty-note {
        padding: 0.4rem 0;
        color: var(--status-muted);
        font-size: 0.86rem;
        line-height: 1.6;
        list-style: none;
    }

    /* ── 面板状态 + 骨架屏 + 消息 ── */
    .status-panel-message {
        display: none;
        margin: 0.6rem 0 0;
        color: var(--status-muted);
        font-size: 0.84rem;
        line-height: 1.55;
    }
    [data-panel].is-empty .status-panel-message,
    [data-panel].is-error .status-panel-message {
        display: block;
    }

    @keyframes status-sk-shimmer {
        0% { background-position: 200% 0; }
        100% { background-position: -200% 0; }
    }
    .status-sk {
        display: inline-block;
        height: 0.92em;
        width: 4.5rem;
        border-radius: 0.4rem;
        vertical-align: -0.12em;
        background: linear-gradient(90deg,
            color-mix(in oklch, var(--line-divider) 26%, var(--card-bg)) 25%,
            color-mix(in oklch, var(--primary) 16%, var(--card-bg)) 45%,
            color-mix(in oklch, var(--line-divider) 26%, var(--card-bg)) 65%);
        background-size: 200% 100%;
        animation: status-sk-shimmer 1.4s ease-in-out infinite;
    }
    .status-sk-sm { width: 2.6rem; }
    .status-sk-num { width: 3.6rem; height: 1.7rem; border-radius: 0.5rem; }
    .status-sk-line { width: min(80%, 20rem); height: 1.05em; }
    .status-sk-chip { width: 4rem; height: 1.5rem; border-radius: 999px; }
    .status-sk-row { width: 100%; height: 2.4rem; border-radius: 0.6rem; }
    .status-skeleton-rows {
        display: flex;
        flex-direction: column;
        gap: 0.55rem;
        padding: 0.15rem 0 0.3rem;
    }
    [data-panel].is-ready .status-skeleton-rows,
    [data-panel].is-empty .status-skeleton-rows,
    [data-panel].is-error .status-skeleton-rows {
        display: none;
    }
    @media (prefers-reduced-motion: reduce) {
        .status-sk { animation: none; }
        .status-refresh.is-loading svg { animation-duration: 2.4s; }
    }

    /* ── 页脚数据来源 ── */
    .status-foot {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.4rem;
        margin-top: 1.15rem;
        padding-top: 0.95rem;
        border-top: 1px solid var(--wg-line);
        color: var(--status-faint);
        font-size: 0.78rem;
    }
    .status-foot a {
        color: var(--primary);
        font-weight: 650;
    }
    .status-foot-sep { opacity: 0.5; }
    .status-foot-hidden,
    [hidden] { display: none !important; }

    @media (hover: hover) and (pointer: fine) {
        .status-refresh:hover { transform: translateY(-2px); }
        .status-chips button:hover { color: var(--primary); }
    }
    @media (max-width: 560px) {
        .status-board { padding: 1rem; }
        .status-head { flex-direction: column; }
        .status-head-actions { flex-direction: row; align-items: center; align-self: flex-start; }
    }
</style>

<script>
import { appName, liveDescription, truncate } from "@utils/asashiki-app-labels";

type ApiResult<T> = {
	data: T | null;
	error?: string;
	ok: boolean;
	status?: number;
};

type HealthResponse = {
	schemaVersion?: number;
	service?: string;
	status?: string;
	time?: string;
	uptimeSeconds?: number;
};

type DeviceItem = {
	appId?: string;
	deviceId?: string;
	deviceName?: string;
	extra?: {
		battery_charging?: boolean;
		battery_percent?: number;
		music?: { title?: string };
		network_type?: string;
	};
	isOnline?: boolean;
	lastSeenAt?: string;
	platform?: string;
	windowTitle?: string;
};

type DevicesResponse = {
	devices?: DeviceItem[];
	fetchedAt?: string;
};

type ActivityItem = {
	appId?: string;
	count?: number;
	totalSeconds?: number;
	windowTitle?: string;
};

type ActivityResponse = {
	date?: string;
	perApp?: ActivityItem[];
	totalSeconds?: number;
};

type TimelineItem = {
	appId?: string;
	deviceId?: string;
	durationSeconds?: number;
	startedAt?: string;
	windowTitle?: string;
};

type TimelineResponse = {
	activities?: TimelineItem[];
	date?: string;
};

type HealthRecord = {
	recordedAt?: string;
	type?: string;
	unit?: string;
	value?: number;
	valueJson?: unknown;
};

type HealthRecordsResponse = {
	records?: HealthRecord[];
};

type HealthMetric = {
	avg?: number;
	count?: number;
	latest?: { recordedAt?: string; value?: number };
	max?: number;
	min?: number;
	sum?: number;
	type?: string;
	unit?: string;
};

type HealthSummaryResponse = {
	fetchedAt?: string;
	metrics?: HealthMetric[];
	sinceIso?: string;
};

type RecentApiResult<T> = {
	activeDate: string;
	result: ApiResult<T>;
	results: Array<{ date: string; result: ApiResult<T> }>;
};

type StatusStore = {
	activity: RecentApiResult<ActivityResponse> | null;
	devices: DeviceItem[];
	healthSummary: HealthSummaryResponse | null;
	heartRecords: ApiResult<HealthRecordsResponse> | null;
	lastLoadedAt: number;
	loadSeq: number;
	refreshTimer: null | number;
	resizeHandler: null | (() => void);
	selectedDevice: string;
	sleepRecords: ApiResult<HealthRecordsResponse> | null;
	stepsRecords: ApiResult<HealthRecordsResponse> | null;
	timeline: RecentApiResult<TimelineResponse> | null;
	timelineDate: string;
	timelineVisible: number;
};

// Asashiki MCP Switch 生态：旧 Core API (api.asashiki.com) 已退役。
// 设备/时间线/健康数据由 device-timeline collector 公网只读 API 提供（link.asashiki.com，
// 即接入 MCP Switch 的同一上游）。switch.asashiki.com 是 OAuth 保护的 /mcp 网关，不适合页面直接 fetch。
const API_BASE = "https://link.asashiki.com";
const API_TIMEOUT = 10_000;
const LOOKBACK_DAYS = 4;
const REFRESH_INTERVAL = 60_000;
const TIMELINE_PAGE_SIZE_DESKTOP = 120;
const TIMELINE_PAGE_SIZE_MOBILE = 18;
const TIMELINE_PAGE_STEP_DESKTOP = 80;
const TIMELINE_PAGE_STEP_MOBILE = 12;
const QUIET_TIMELINE_APP_IDS = new Set(["windows.afk", "windows.idle"]);
const statusStore = new WeakMap<HTMLElement, StatusStore>();

function getStore(root: HTMLElement) {
	let store = statusStore.get(root);
	if (!store) {
		store = {
			activity: null,
			devices: [],
			healthSummary: null,
			heartRecords: null,
			lastLoadedAt: 0,
			loadSeq: 0,
			refreshTimer: null,
			resizeHandler: null,
			selectedDevice: "all",
			sleepRecords: null,
			stepsRecords: null,
			timeline: null,
			timelineDate: todayShanghai(),
			timelineVisible: timelinePageSize(),
		};
		statusStore.set(root, store);
	}
	return store;
}

function isDesktopTimeline() {
	return window.matchMedia("(min-width: 1025px)").matches;
}

function timelinePageSize() {
	return isDesktopTimeline() ? TIMELINE_PAGE_SIZE_DESKTOP : TIMELINE_PAGE_SIZE_MOBILE;
}

function timelinePageStep() {
	return isDesktopTimeline() ? TIMELINE_PAGE_STEP_DESKTOP : TIMELINE_PAGE_STEP_MOBILE;
}

function todayShanghai() {
	return new Intl.DateTimeFormat("sv-SE", { timeZone: "Asia/Shanghai" }).format(new Date());
}

function dateOffsetShanghai(baseDate: string, offsetDays: number) {
	const date = new Date(`${baseDate}T00:00:00+08:00`);
	date.setUTCDate(date.getUTCDate() + offsetDays);
	return new Intl.DateTimeFormat("sv-SE", { timeZone: "Asia/Shanghai" }).format(date);
}

function recentDates() {
	const today = todayShanghai();
	return Array.from({ length: LOOKBACK_DAYS }, (_, index) => dateOffsetShanghai(today, -index));
}

function relativeDateLabel(date: string) {
	const dates = recentDates();
	if (date === dates[0]) return "今天";
	if (date === dates[1]) return "昨天";
	if (date === dates[2]) return "前天";
	if (date === dates[3]) return "大前天";
	return new Intl.DateTimeFormat("zh-CN", {
		day: "2-digit",
		month: "2-digit",
		timeZone: "Asia/Shanghai",
	}).format(new Date(`${date}T00:00:00+08:00`));
}

function dateMetaLabel(date: string) {
	return `${date.slice(5)} · 00:00-24:00`;
}

function formatClock(value?: string) {
	if (!value) return "--:--";
	return new Intl.DateTimeFormat("zh-CN", {
		hour: "2-digit",
		minute: "2-digit",
		timeZone: "Asia/Shanghai",
	}).format(new Date(value));
}

function formatDuration(seconds = 0) {
	if (!seconds) return "进行中";
	if (seconds < 60) return `${Math.max(1, Math.round(seconds))}秒`;
	const minutes = Math.round(seconds / 60);
	if (minutes < 60) return `${minutes}分钟`;
	const hours = Math.floor(minutes / 60);
	const rest = minutes % 60;
	return rest ? `${hours}h${rest}m` : `${hours}h`;
}

function formatMinutes(minutes = 0) {
	if (!minutes) return "暂无";
	if (minutes < 60) return `${Math.round(minutes)}分钟`;
	const hours = Math.floor(minutes / 60);
	const rest = Math.round(minutes % 60);
	return rest ? `${hours}h${rest}m` : `${hours}h`;
}

function dateKeyShanghai(value?: string) {
	if (!value) return "";
	const date = new Date(value);
	if (!Number.isFinite(date.getTime())) return "";
	return new Intl.DateTimeFormat("sv-SE", { timeZone: "Asia/Shanghai" }).format(date);
}

function timeAgo(value?: string) {
	if (!value) return "未知时间";
	const diff = Date.now() - new Date(value).getTime();
	if (!Number.isFinite(diff)) return "未知时间";
	if (diff < 60_000) return "刚刚";
	const minutes = Math.floor(diff / 60_000);
	if (minutes < 60) return `${minutes}分钟前`;
	const hours = Math.floor(minutes / 60);
	if (hours < 24) return `${hours}小时前`;
	return `${Math.floor(hours / 24)}天前`;
}

function setText(root: ParentNode, selector: string, value: string) {
	const element = root.querySelector(selector);
	if (element) element.textContent = value;
}

function clear(element: Element | null) {
	if (element) element.replaceChildren();
}

type Chip = string | { label: string; tone?: string };

function renderChips(root: ParentNode, selector: string, labels: Chip[]) {
	const container = root.querySelector(selector);
	if (!container) return;
	container.replaceChildren(
		...labels.map((entry) => {
			const { label, tone } =
				typeof entry === "string" ? { label: entry, tone: "" } : entry;
			const chip = document.createElement("span");
			if (tone) chip.dataset.tone = tone;
			chip.textContent = label;
			return chip;
		}),
	);
}

// 在线状态用一颗 CSS 圆点表达，避免在数据里塞 emoji
function setOnlineTone(root: ParentNode, online: boolean) {
	const dd = root.querySelector<HTMLElement>("[data-online-count]");
	if (dd) dd.dataset.tone = online ? "online" : "offline";
}

// 「暂无 / --」这类占位值别用大数字字号，缩小成普通文字
function markEmptyMetrics(root: ParentNode) {
	for (const el of root.querySelectorAll<HTMLElement>(".wg-value strong")) {
		const text = (el.textContent || "").trim();
		el.classList.toggle("is-na", text === "暂无" || text === "--" || text === "");
	}
}

function timestamp(value?: string) {
	const time = value ? new Date(value).getTime() : 0;
	return Number.isFinite(time) ? time : 0;
}

function nowShanghaiStamp() {
	return new Intl.DateTimeFormat("zh-CN", {
		hour: "2-digit",
		minute: "2-digit",
		month: "2-digit",
		second: "2-digit",
		timeZone: "Asia/Shanghai",
		year: "numeric",
		day: "2-digit",
	}).format(new Date());
}

async function getJson<T>(path: string): Promise<ApiResult<T>> {
	let timer = 0;
	try {
		const controller = new AbortController();
		timer = window.setTimeout(() => controller.abort(), API_TIMEOUT);
		const response = await fetch(`${API_BASE}${path}`, {
			headers: { accept: "application/json" },
			signal: controller.signal,
		});
		if (!response.ok) return { data: null, ok: false, status: response.status };
		return { data: (await response.json()) as T, ok: true, status: response.status };
	} catch (error) {
		return { data: null, error: error instanceof Error ? error.message : String(error), ok: false };
	} finally {
		if (timer) window.clearTimeout(timer);
	}
}

async function getRecentBundle<T>(
	dates: string[],
	pathForDate: (date: string) => string,
	hasData: (data: T | null) => boolean,
): Promise<RecentApiResult<T>> {
	const results = await Promise.all(
		dates.map(async (date) => ({
			date,
			result: await getJson<T>(pathForDate(date)),
		})),
	);
	const active = results.find((item) => item.result.ok && hasData(item.result.data)) || results.find((item) => item.result.ok) || results[0];
	return { activeDate: active?.date || dates[0], result: active?.result || { data: null, ok: false }, results };
}

function setPanelState(root: HTMLElement, name: string, state: "empty" | "error" | "loading" | "ready", message = "") {
	const panel = root.querySelector<HTMLElement>(`[data-panel="${name}"]`);
	if (!panel) return;
	panel.classList.toggle("is-loading", state === "loading");
	panel.classList.toggle("is-error", state === "error");
	panel.classList.toggle("is-empty", state === "empty");
	panel.classList.toggle("is-ready", state === "ready");
	setText(panel, "[data-panel-message]", message);
}

function primaryDevice(devices: DeviceItem[], selectedDevice: string) {
	if (selectedDevice !== "all") return devices.find((item) => item.deviceId === selectedDevice) || null;
	const online = devices.filter((item) => item.isOnline).sort((a, b) => timestamp(b.lastSeenAt) - timestamp(a.lastSeenAt));
	if (online.length) return online[0];
	return [...devices].sort((a, b) => timestamp(b.lastSeenAt) - timestamp(a.lastSeenAt))[0] || null;
}

function deviceStatusMeta(device: DeviceItem) {
	const app = appName(device.appId);
	const lastSeen = timeAgo(device.lastSeenAt);
	if (device.isOnline) return `${lastSeen} · ${app}`;
	return `离线 ${lastSeen} · ${app}`;
}

function offlineDescription(device: DeviceItem | null) {
	if (!device) return "Asashiki 暂时离线。";
	const name = device.deviceName || device.deviceId || "设备";
	const app = appName(device.appId);
	return `${name} 已离线 ${timeAgo(device.lastSeenAt)}，上次停在 ${app}。`;
}

function renderDeviceTabs(root: HTMLElement) {
	const store = getStore(root);
	const tabs = root.querySelector("[data-device-tabs]");
	clear(tabs);
	const online = store.devices.filter((device) => device.isOnline).length;
	const devicesByRecent = [...store.devices].sort((a, b) => timestamp(b.lastSeenAt) - timestamp(a.lastSeenAt));
	const entries = [
		{ id: "all", label: "总览", meta: `${online}/${store.devices.length} 在线` },
		...devicesByRecent.map((device) => ({
			id: device.deviceId || "unknown",
			// 只显示设备名，去掉「我的」前缀，详情放到 title 悬浮里
			label: (device.deviceName || device.deviceId || "未知设备").replace(/^我的/, ""),
			meta: deviceStatusMeta(device),
		})),
	];
	for (const entry of entries) {
		const button = document.createElement("button");
		button.type = "button";
		button.className = entry.id === store.selectedDevice ? "is-active" : "";
		button.title = entry.meta;
		button.textContent = entry.label;
		button.addEventListener("click", () => {
			store.selectedDevice = entry.id;
			store.timelineVisible = timelinePageSize();
			renderNow(root);
			renderTimeline(root);
			syncTimelineHeight(root);
		});
		tabs?.append(button);
	}
}

function healthMetric(store: StatusStore, type: string) {
	return store.healthSummary?.metrics?.find((item) => item.type === type) || null;
}

function stepsLiveLabel(store: StatusStore) {
	const steps = healthMetric(store, "steps");
	if (steps && typeof steps.sum === "number" && steps.sum > 0) return Math.round(steps.sum).toLocaleString("en-US");
	return "暂无";
}

function latestHeartLabel(store: StatusStore) {
	const latest = (store.heartRecords?.ok ? store.heartRecords.data?.records || [] : [])
		.filter((item) => item.type === "heart_rate" && typeof item.value === "number")
		.sort((a, b) => timestamp(b.recordedAt) - timestamp(a.recordedAt))[0];
	return latest ? String(Math.round(latest.value || 0)) : "暂无";
}

function renderNow(root: HTMLElement) {
	const store = getStore(root);
	const devices = store.devices;
	renderDeviceTabs(root);

	if (!devices.length) {
		setText(root, "[data-now-sentence]", "设备时间线在线时，这里会显示当前设备正在做什么。");
		setText(root, "[data-live-desc]", "还没有设备上报。");
		renderChips(root, "[data-live-detail]", ["设备未上报", "时间线继续读取", "模块独立回退"]);
		setText(root, "[data-selected-device-label]", "总览");
		setText(root, "[data-online-count]", "0 / 0");
		setOnlineTone(root, false);
		setText(root, "[data-current-app]", "暂无");
		setText(root, "[data-health-steps-live]", stepsLiveLabel(store));
		setText(root, "[data-health-heart-live]", latestHeartLabel(store));
		markEmptyMetrics(root);
		return;
	}

	const online = devices.filter((item) => item.isOnline);
	const selected = primaryDevice(devices, store.selectedDevice);
	const activeDeviceLabel = store.selectedDevice === "all" ? "总览" : selected?.deviceName || selected?.deviceId || "设备";
	const live = selected
		? selected.isOnline
			? liveDescription({ appId: selected.appId, windowTitle: selected.windowTitle })
			: offlineDescription(selected)
		: "Asashiki 暂时离线。";
	const app = selected ? appName(selected.appId) : "暂无";
	const chips: Chip[] = selected
		? [
				{
					label: selected.isOnline ? "在线" : "离线",
					tone: selected.isOnline ? "online" : "offline",
				},
				timeAgo(selected.lastSeenAt),
				app,
				typeof selected.extra?.battery_percent === "number"
					? `${selected.extra.battery_charging ? "充电 " : ""}${selected.extra.battery_percent}%`
					: "",
				selected.extra?.network_type ? `${selected.extra.network_type}` : "",
			].filter(
				(label): label is Chip =>
					typeof label === "string" ? Boolean(label) : true,
			)
		: [{ label: `${online.length} 台设备在线`, tone: "online" }];

	setText(root, "[data-now-sentence]", live);
	setText(root, "[data-live-desc]", live);
	renderChips(root, "[data-live-detail]", chips);
	setText(root, "[data-selected-device-label]", activeDeviceLabel);
	setText(root, "[data-online-count]", `${online.length} / ${devices.length}`);
	setOnlineTone(root, online.length > 0);
	setText(root, "[data-current-app]", app);
	setText(root, "[data-health-steps-live]", stepsLiveLabel(store));
	setText(root, "[data-health-heart-live]", latestHeartLabel(store));
	markEmptyMetrics(root);
}

function healthMetricsForDate(store: StatusStore, date: string) {
	const stepsRecords = store.stepsRecords?.ok ? store.stepsRecords.data?.records || [] : [];
	const sleepRecords = store.sleepRecords?.ok ? store.sleepRecords.data?.records || [] : [];
	const dayStepsRecords = stepsRecords.filter((item) => dateKeyShanghai(item.recordedAt) === date);
	const daySleepRecords = sleepRecords.filter((item) => dateKeyShanghai(item.recordedAt) === date);
	const stepValues = dayStepsRecords
		.filter((item) => item.type === "steps" && typeof item.value === "number")
		.map((item) => item.value as number);
	const steps = stepValues.length ? stepValues.reduce((sum, value) => sum + value, 0) : null;
	const sleep = daySleepRecords
		.filter((item) => item.type === "sleep" && typeof item.value === "number")
		.sort((a, b) => timestamp(b.recordedAt) - timestamp(a.recordedAt))[0];
	return { sleep, steps };
}

function activityForSelectedDate(store: StatusStore) {
	return store.activity?.results.find((item) => item.date === store.timelineDate) || null;
}

function renderHealth(root: HTMLElement) {
	const store = getStore(root);
	const metrics = healthMetricsForDate(store, store.timelineDate);
	const stepsUnavailable = !store.stepsRecords?.ok;
	const sleepUnavailable = !store.sleepRecords?.ok;

	if (stepsUnavailable && sleepUnavailable) {
		setText(root, "[data-health-steps]", "暂无");
		setText(root, "[data-health-sleep]", "暂无");
		setText(root, "[data-body-heading]", "不可用");
		markEmptyMetrics(root);
		setPanelState(root, "body", "error", "健康记录暂时没有回应。");
		return;
	}
	const hasRecord = Boolean(metrics.steps || metrics.sleep);
	const dayLabel = relativeDateLabel(store.timelineDate);
	setText(root, "[data-health-steps]", metrics.steps ? String(Math.round(metrics.steps)) : "暂无");
	setText(root, "[data-health-sleep]", metrics.sleep ? formatMinutes(metrics.sleep.value || 0) : "暂无");
	setText(root, "[data-body-heading]", hasRecord ? `${dayLabel}记录` : `${dayLabel}暂无`);
	markEmptyMetrics(root);
	setPanelState(root, "body", hasRecord ? "ready" : "empty", hasRecord ? "" : `${dayLabel}暂时没有健康记录。`);
}

function renderActivity(root: HTMLElement, bundle?: RecentApiResult<ActivityResponse>) {
	const store = getStore(root);
	if (bundle) store.activity = bundle;
	const list = root.querySelector("[data-app-list]");
	clear(list);
	const active = activityForSelectedDate(store);
	const result = active?.result;
	const apps = (result?.data?.perApp || [])
		.filter((item) => !QUIET_TIMELINE_APP_IDS.has(item.appId || ""))
		.filter((item) => (item.totalSeconds || 0) > 0)
		.sort((a, b) => (b.totalSeconds || 0) - (a.totalSeconds || 0));

	if (!result?.ok) {
		setText(root, "[data-activity-total]", "不可用");
		setPanelState(root, "activity", "error", "应用统计暂时没有回应。");
		return;
	}

	if (!apps.length) {
		setText(root, "[data-activity-total]", "暂无");
		setPanelState(root, "activity", "empty", "最近几天没有可展示的应用统计。");
		return;
	}

	const total = apps.reduce((sum, item) => sum + (item.totalSeconds || 0), 0);
	const max = Math.max(...apps.map((item) => item.totalSeconds || 0), 1);
	setText(root, "[data-activity-total]", `${relativeDateLabel(store.timelineDate)} · ${formatDuration(total)}`);

	for (const item of apps) {
		const row = document.createElement("div");
		row.className = "status-app-row";
		row.title = item.appId || "";
		const top = document.createElement("div");
		top.className = "status-app-top";
		const name = document.createElement("strong");
		name.className = "status-app-name";
		name.textContent = appName(item.appId);
		const time = document.createElement("span");
		time.className = "status-app-time";
		time.textContent = formatDuration(item.totalSeconds || 0);
		top.append(name, time);
		const detail = document.createElement("span");
		detail.className = "status-app-detail";
		detail.textContent = `${item.count || 0} 次记录`;
		const track = document.createElement("div");
		track.className = "status-app-track";
		const fill = document.createElement("span");
		fill.style.setProperty("--ratio", `${Math.max(5, ((item.totalSeconds || 0) / max) * 100)}%`);
		track.append(fill);
		row.append(top, detail, track);
		list?.append(row);
	}
	setPanelState(root, "activity", "ready");
}

function timelineRowsForDate(store: StatusStore, date: string) {
	const dated = store.timeline?.results.find((item) => item.date === store.timelineDate);
	const target = store.timeline?.results.find((item) => item.date === date) || dated;
	const activities = target?.result.data?.activities || [];
	const scoped = store.selectedDevice === "all" ? activities : activities.filter((item) => item.deviceId === store.selectedDevice);
	const readable = scoped.filter((item) => !QUIET_TIMELINE_APP_IDS.has(item.appId || "") && item.durationSeconds !== 0);
	return readable.sort((a, b) => new Date(b.startedAt || 0).getTime() - new Date(a.startedAt || 0).getTime());
}

function timelineRowsForStore(store: StatusStore) {
	return timelineRowsForDate(store, store.timelineDate);
}

function appendTimeline(root: HTMLElement, preserveScroll = true) {
	const store = getStore(root);
	const rows = timelineRowsForStore(store);
	if (store.timelineVisible >= rows.length) return;
	const scroll = root.querySelector<HTMLElement>("[data-timeline-scroll]");
	const scrollTop = scroll?.scrollTop ?? 0;
	store.timelineVisible = Math.min(rows.length, store.timelineVisible + timelinePageStep());
	renderTimeline(root);
	if (preserveScroll) {
		window.requestAnimationFrame(() => {
			const nextScroll = root.querySelector<HTMLElement>("[data-timeline-scroll]");
			if (nextScroll) nextScroll.scrollTop = scrollTop;
		});
	}
}

function ensureTimelineScrollable(root: HTMLElement) {
	window.requestAnimationFrame(() => {
		const store = getStore(root);
		const rows = timelineRowsForStore(store);
		const scroll = root.querySelector<HTMLElement>("[data-timeline-scroll]");
		if (!scroll || store.timelineVisible >= rows.length) return;
		if (scroll.scrollHeight <= scroll.clientHeight * 1.4) {
			store.timelineVisible = Math.min(rows.length, store.timelineVisible + timelinePageStep());
			renderTimeline(root);
		}
	});
}

function syncTimelineHeight(root: HTMLElement) {
	window.requestAnimationFrame(() => {
		const panel = root.querySelector<HTMLElement>('[data-panel="timeline"]');
		const side = root.querySelector<HTMLElement>(".status-side");
		if (!panel || !side) return;

		if (!isDesktopTimeline()) {
			panel.style.removeProperty("--status-timeline-height");
			return;
		}

		const sideHeight = Math.ceil(side.getBoundingClientRect().height);
		if (sideHeight > 0) {
			panel.style.setProperty("--status-timeline-height", `${sideHeight}px`);
			ensureTimelineScrollable(root);
		}
	});
}

function setSelectedDate(root: HTMLElement, date: string) {
	const store = getStore(root);
	store.timelineDate = date;
	store.timelineVisible = timelinePageSize();
	const timelineScroll = root.querySelector<HTMLElement>("[data-timeline-scroll]");
	const appScroll = root.querySelector<HTMLElement>("[data-app-scroll]");
	if (timelineScroll) timelineScroll.scrollTop = 0;
	if (appScroll) appScroll.scrollTop = 0;
	renderTimeline(root);
	renderActivity(root);
	renderHealth(root);
	syncTimelineHeight(root);
}

function renderDateTabs(root: HTMLElement) {
	const store = getStore(root);
	const dayTabs = root.querySelector("[data-status-days]");
	clear(dayTabs);
	const entries = store.timeline?.results.length ? store.timeline.results : recentDates().map((date) => ({ date, result: { data: null, ok: false } }));
	setText(root, "[data-selected-date-label]", relativeDateLabel(store.timelineDate));
	setText(root, "[data-selected-date-meta]", dateMetaLabel(store.timelineDate));

	for (const entry of entries) {
		const selectedTotal = timelineRowsForDate(store, entry.date).length;
		const button = document.createElement("button");
		button.type = "button";
		button.className = entry.date === store.timelineDate ? "is-active" : "";
		button.textContent = `${relativeDateLabel(entry.date)} · ${selectedTotal}`;
		button.title = `${entry.date} · Asia/Shanghai`;
		button.addEventListener("click", () => setSelectedDate(root, entry.date));
		dayTabs?.append(button);
	}
}

function renderTimeline(root: HTMLElement) {
	const store = getStore(root);
	const list = root.querySelector("[data-timeline-list]");
	clear(list);

	if (!store.timeline) {
		renderDateTabs(root);
		setPanelState(root, "timeline", "loading", "正在读取时间线。");
		return;
	}

	renderDateTabs(root);

	const rows = timelineRowsForStore(store);
	store.timelineVisible = Math.max(store.timelineVisible, Math.min(rows.length, timelinePageSize()));
	const limit = Math.min(store.timelineVisible, rows.length);
	setText(root, "[data-timeline-count]", `${relativeDateLabel(store.timelineDate)} · ${rows.length} 条`);

	if (!rows.length) {
		setPanelState(root, "timeline", "empty", "当前日期和设备筛选下没有记录。");
		const note = document.createElement("li");
		note.className = "status-empty-note";
		note.textContent = "可以切换上方日期或左侧设备；如果当天没有上报记录，这里会保持安静而不是堆占位符。";
		list?.append(note);
		return;
	}

	for (const activity of rows.slice(0, limit)) {
		const item = document.createElement("li");
		item.className = "status-timeline-item";
		const time = document.createElement("time");
		time.className = "status-timeline-time";
		time.textContent = formatClock(activity.startedAt);
		const main = document.createElement("div");
		main.className = "status-timeline-main";
		const title = document.createElement("strong");
		title.textContent = liveDescription({ appId: activity.appId, who: "", windowTitle: activity.windowTitle }).trim();
		const detail = document.createElement("span");
		const device = store.devices.find((candidate) => candidate.deviceId === activity.deviceId);
		detail.textContent = `${device?.deviceName || activity.deviceId || "device"} · ${formatDuration(activity.durationSeconds || 0)}`;
		main.append(title, detail);
		const app = document.createElement("span");
		app.className = "status-timeline-app";
		app.textContent = truncate(appName(activity.appId), 12);
		item.append(time, main, app);
		list?.append(item);
	}

	setPanelState(root, "timeline", "ready");
	ensureTimelineScrollable(root);
}

function renderService(root: HTMLElement, health: ApiResult<HealthResponse>) {
	const store = getStore(root);
	const online = health.ok && health.data?.status === "ok";
	const onlineDevices = store.devices.filter((item) => item.isOnline).length;
	setText(root, "[data-core-state]", online ? "online" : "不可用");
	setText(root, "[data-schema-state]", online && health.data?.schemaVersion ? `schema v${health.data.schemaVersion}` : online ? health.data?.service || "online" : "--");
	setText(root, "[data-connectors-state]", `${onlineDevices}/${store.devices.length} 在线`);
	setText(root, "[data-service-heading]", online ? "online" : "异常");
	setPanelState(root, "service", online ? "ready" : "error", online ? "" : "设备时间线服务健康检查没有返回 ok。");
}

async function loadStatus(root: HTMLElement) {
	const store = getStore(root);
	const seq = store.loadSeq + 1;
	store.loadSeq = seq;
	const refresh = root.querySelector<HTMLButtonElement>("[data-status-refresh]");
	refresh?.classList.add("is-loading");
	refresh?.setAttribute("aria-busy", "true");
	root.classList.add("is-booting");
	for (const name of ["timeline", "activity", "body", "service"]) {
		setPanelState(root, name, "loading", "");
	}

	// 仍然有效（没被更新的加载覆盖、节点还在文档里）才落数据
	const fresh = () => seq === store.loadSeq && document.body.contains(root);

	// 所有请求一次性并行发出；谁先回来就先渲染谁的板块，
	// 不再让整页卡在最慢的那一个请求上（这正是「读取中」久不消失的根因）。
	const dates = recentDates();
	const pHealth = getJson<HealthResponse>("/health");
	const pDevices = getJson<DevicesResponse>("/api/devices/current");
	const pSummary = getJson<HealthSummaryResponse>("/api/devices/health/summary");
	const pSteps = getJson<HealthRecordsResponse>("/api/devices/health/records?type=steps&limit=200");
	const pHeart = getJson<HealthRecordsResponse>("/api/devices/health/records?type=heart_rate&limit=60");
	const pSleep = getJson<HealthRecordsResponse>("/api/devices/health/records?type=sleep&limit=30");
	const pTimeline = getRecentBundle<TimelineResponse>(dates, (date) => `/api/devices/timeline-query?date=${date}&limit=120`, (data) => Boolean(data?.activities?.length));
	const pActivity = getRecentBundle<ActivityResponse>(dates, (date) => `/api/devices/activity-summary?date=${date}`, (data) => Boolean(data?.perApp?.some((item) => (item.totalSeconds || 0) > 0)));

	const stamp = () =>
		setText(
			root,
			"[data-updated-at]",
			new Intl.DateTimeFormat("zh-CN", { hour: "2-digit", minute: "2-digit", second: "2-digit", timeZone: "Asia/Shanghai" }).format(new Date()),
		);

	// 顶部「实时」组：设备 + 健康摘要 + 步数/心率 —— 到齐就先把 hero 点亮
	const live = Promise.all([pDevices, pSummary, pSteps, pHeart]).then(([devices, summary, steps, heart]) => {
		if (!fresh()) return;
		store.devices = devices.ok ? devices.data?.devices || [] : [];
		if (store.selectedDevice !== "all" && !store.devices.some((item) => item.deviceId === store.selectedDevice)) {
			store.selectedDevice = "all";
			store.timelineVisible = timelinePageSize();
		}
		store.healthSummary = summary.ok ? summary.data : null;
		store.stepsRecords = steps;
		store.heartRecords = heart;
		store.lastLoadedAt = Date.now();
		root.classList.remove("is-booting");
		renderNow(root);
		stamp();
	});

	// 身体抽屉：摘要 + 步数 + 睡眠
	const body = Promise.all([pSummary, pSteps, pSleep]).then(([summary, steps, sleep]) => {
		if (!fresh()) return;
		store.healthSummary = summary.ok ? summary.data : store.healthSummary;
		store.stepsRecords = steps;
		store.sleepRecords = sleep;
		renderHealth(root);
	});

	// 时间线（多日 bundle，可能较慢，独立渲染，绝不拖累 hero）
	const timeline = pTimeline.then((bundle) => {
		if (!fresh()) return;
		const prev = store.timelineDate;
		store.timeline = bundle;
		store.timelineDate = bundle.results.some((item) => item.date === prev) ? prev : bundle.activeDate;
		if (store.timelineDate !== prev) store.timelineVisible = timelinePageSize();
		renderTimeline(root);
		syncTimelineHeight(root);
	});

	// 应用统计
	const activity = pActivity.then((bundle) => {
		if (fresh()) renderActivity(root, bundle);
	});

	// 数据服务 + 顶部 API 指示灯
	const service = pHealth.then((health) => {
		if (!fresh()) return;
		const apiOnline = health.ok && health.data?.status === "ok";
		setText(root, "[data-api-state]", apiOnline ? "设备时间线 在线" : "设备时间线 未响应");
		root.querySelector("[data-api-pulse]")?.classList.toggle("is-error", !apiOnline);
		renderService(root, health);
	});

	// 全部尘埃落定后收尾（停转刷新按钮）。各板块出错由各自 render 兜底，互不牵连。
	try {
		await Promise.allSettled([live, body, timeline, activity, service]);
	} finally {
		if (seq === store.loadSeq) {
			root.classList.remove("is-booting");
			refresh?.classList.remove("is-loading");
			refresh?.removeAttribute("aria-busy");
		}
	}
}

function initStatusPage() {
	document.querySelectorAll<HTMLElement>("[data-status-page]").forEach((root) => {
		const store = getStore(root);
		if (root.dataset.statusBound) {
			syncTimelineHeight(root);
			if (!store.lastLoadedAt || Date.now() - store.lastLoadedAt > 15_000) {
				loadStatus(root);
			}
			return;
		}
		root.dataset.statusBound = "true";
		root.querySelector("[data-status-refresh]")?.addEventListener("click", () => loadStatus(root));
		root.querySelector("[data-timeline-scroll]")?.addEventListener("scroll", (event) => {
			const scroll = event.currentTarget as HTMLElement;
			if (scroll.scrollTop + scroll.clientHeight >= scroll.scrollHeight - 96) appendTimeline(root);
		});
		const resizeHandler = () => syncTimelineHeight(root);
		store.resizeHandler = resizeHandler;
		window.addEventListener("resize", resizeHandler);
		loadStatus(root);
		store.refreshTimer = window.setInterval(() => {
			if (!document.body.contains(root)) {
				const latest = getStore(root);
				delete root.dataset.statusBound;
				window.removeEventListener("resize", resizeHandler);
				if (latest.refreshTimer) window.clearInterval(latest.refreshTimer);
				latest.refreshTimer = null;
				return;
			}
			loadStatus(root);
		}, REFRESH_INTERVAL);
	});
}

// 数据一直不出来 / 要刷新才出来的真正原因：本站用的是 @swup/astro（swup），
// 并不会触发 Astro ClientRouter 的 astro:page-load 事件，所以之前挂在它上面的
// initStatusPage 根本没跑。改用本代码库统一的 swup 惯例（见 Layout / GlobalAudioPlayer /
// AiVisualInteractions）：首屏立即调用一次，之后交给 swup 的 page:view / content:replace 钩子。
// initStatusPage 用 dataset.statusBound 幂等，重复触发安全。
initStatusPage();

const setupStatusRouting = () => {
	window.swup?.hooks?.on("page:view", initStatusPage);
	window.swup?.hooks?.on("content:replace", initStatusPage);
};

if (window.swup?.hooks) {
	setupStatusRouting();
} else {
	document.addEventListener("swup:enable", setupStatusRouting);
}
</script>
