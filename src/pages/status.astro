---
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { Icon } from "astro-icon/components";
---

<MainGridLayout title="状态" description="Asashiki 的实时状态">
    <div class="flex w-full max-w-[100vw] rounded-[var(--radius-large)] overflow-hidden relative mb-4">
        <article class="card-base status-board relative w-full max-w-[100vw]" data-status-page>
            <header class="status-head onload-animation">
                <div class="status-head-copy">
                    <h1>状态</h1>
                    <p data-now-sentence>正在读取 Asashiki 的当前状态。</p>
                </div>
                <div class="status-head-actions">
                    <button class="status-refresh" type="button" data-status-refresh aria-label="刷新">
                        <Icon name="material-symbols:refresh-rounded" class="text-lg"></Icon>
                        <span>刷新</span>
                    </button>
                    <time data-updated-at>--:--</time>
                </div>
            </header>

            <!-- 设备切换 -->
            <div class="status-controls onload-animation" style="animation-delay: calc(var(--content-delay) + 40ms);">
                <nav class="status-chips" aria-label="设备筛选" data-device-tabs>
                    <button class="is-active" type="button">总览</button>
                </nav>
            </div>

            <div class="status-grid status-realtime-grid onload-animation" style="animation-delay: calc(var(--content-delay) + 80ms);">
                <!-- 心率 -->
                <article class="wg wg-metric wg-heart">
                    <div class="wg-top"><Icon name="material-symbols:favorite-outline-rounded" class="wg-icon"></Icon><span>心率</span></div>
                    <div class="wg-value"><strong data-health-heart-live><span class="status-sk status-sk-num"></span></strong><em>bpm</em></div>
                </article>
                <!-- 步数 -->
                <article class="wg wg-metric wg-steps">
                    <div class="wg-top"><Icon name="material-symbols:directions-walk-rounded" class="wg-icon"></Icon><span>步数</span></div>
                    <div class="wg-value"><strong data-health-steps-live><span class="status-sk status-sk-num"></span></strong><em>步</em></div>
                </article>
                <!-- 睡眠 -->
                <article class="wg wg-metric wg-sleep">
                    <div class="wg-top"><Icon name="material-symbols:bedtime-outline-rounded" class="wg-icon"></Icon><span>睡眠</span></div>
                    <div class="wg-value"><strong data-health-sleep><span class="status-sk status-sk-num"></span></strong></div>
                </article>
                <!-- 在线设备 -->
                <article class="wg wg-metric wg-online">
                    <div class="wg-top"><Icon name="material-symbols:devices-other-outline-rounded" class="wg-icon"></Icon><span>在线设备</span></div>
                    <div class="wg-value"><strong data-online-count><span class="status-sk status-sk-num"></span></strong><em>在线 / 全部</em></div>
                </article>

                <!-- 此刻 -->
                <article class="wg wg-now">
                    <div class="wg-top"><Icon name="material-symbols:bolt-rounded" class="wg-icon"></Icon><span>此刻</span><span class="wg-now-device" data-selected-device-label>总览</span></div>
                    <strong class="wg-now-desc" data-live-desc><span class="status-sk status-sk-line"></span></strong>
                    <div class="wg-chips" data-live-detail>
                        <span class="status-sk status-sk-chip"></span>
                        <span class="status-sk status-sk-chip"></span>
                    </div>
                    <!-- 当前应用（隐藏承载，供 renderNow 写入，也可展示） -->
                    <span class="wg-now-app" data-current-app hidden></span>
                </article>
            </div>

            <section class="status-history onload-animation" style="animation-delay: calc(var(--content-delay) + 120ms);" aria-labelledby="status-history-title">
                <div class="status-history-head">
                    <h2 id="status-history-title">历史足迹</h2>
                    <div class="status-date">
                        <span class="status-date-label" data-selected-date-label>今天</span>
                        <div class="status-date-tabs" data-status-days></div>
                    </div>
                </div>

                <div class="status-grid status-history-grid">
                <!-- 今日应用 -->
                <article class="wg wg-apps" data-panel="activity">
                    <div class="wg-top"><Icon name="material-symbols:bar-chart-rounded" class="wg-icon"></Icon><span data-activity-title>今日应用</span><span class="wg-sub" data-activity-total></span></div>
                    <div class="status-app-scroll" data-app-scroll>
                        <div class="status-app-list" data-app-list></div>
                        <div class="status-skeleton-rows" aria-hidden="true">
                            <span class="status-sk status-sk-row"></span>
                            <span class="status-sk status-sk-row"></span>
                            <span class="status-sk status-sk-row"></span>
                        </div>
                        <p class="status-panel-message" data-panel-message></p>
                    </div>
                </article>

                <!-- 今日足迹（时间线） -->
                <article class="wg wg-timeline" data-panel="timeline">
                    <div class="wg-top"><Icon name="material-symbols:timeline" class="wg-icon"></Icon><span data-timeline-title>今日足迹</span><span class="wg-sub" data-timeline-count></span></div>
                    <div class="status-timeline-scroll" data-timeline-scroll>
                        <ol class="status-timeline-list" data-timeline-list></ol>
                        <div class="status-skeleton-rows" aria-hidden="true">
                            <span class="status-sk status-sk-row"></span>
                            <span class="status-sk status-sk-row"></span>
                            <span class="status-sk status-sk-row"></span>
                            <span class="status-sk status-sk-row"></span>
                        </div>
                        <p class="status-panel-message" data-panel-message></p>
                    </div>
                </article>
                </div>
            </section>

            <!-- 数据来源：低调页脚，承载 service 面板写入 -->
            <footer class="status-foot" data-panel="service">
                <span class="status-foot-dot" data-body-heading hidden></span>
                <span>数据来自 <a href="https://link.asashiki.com" target="_blank" rel="noopener">Hibi 日々</a> 设备时间线</span>
                <span class="status-foot-sep">·</span>
                <span data-api-state>连接中</span>
                <span class="status-foot-sep" data-service-heading hidden></span>
                <span class="status-foot-hidden" data-schema-state hidden></span>
                <span class="status-foot-hidden" data-core-state hidden></span>
                <span class="status-foot-hidden" data-connectors-state hidden></span>
            </footer>
        </article>
    </div>
</MainGridLayout>

<style is:global>
    /* ── 状态页 · 桌面小组件风 ─────────────────────────────────
       设计语言与时间胶囊/探索同源：站点原生卡片 + 樱粉主色点缀。
       去掉了旧版的 dashboard 细线条 / 绿色脉冲点 / 控制台英文 kicker。
       字体：本页全部走默认字体（衬线在这个页面上不合适，已退回普通字）。 */
    .status-board {
        /* 文字必须是中性色：整页文字染上主题色会显得花哨（已踩过坑） */
        --status-text: rgb(24 24 27);
        --status-muted: rgb(84 84 92);
        --status-faint: rgb(122 116 125);
        /* 状态页不用衬线，全走默认字体（衬线在这个页面上不合适） */
        --wg-serif: inherit;
        --wg-bg: color-mix(in oklch, var(--primary) 4%, var(--card-bg));
        --wg-line: color-mix(in oklch, var(--line-divider) 55%, transparent);
        /* 在线=绿，语义色不跟随主题 hue */
        --status-online: oklch(0.68 0.12 155);
        position: relative;
        overflow: hidden;
        padding: 1.4rem 1.4rem 1.5rem;
        color: var(--status-text);
        background: var(--card-bg);
        font-size: 14px;
        line-height: 1.5;
    }
    /* 单一同源浅樱柔光，作 hero 光晕（与时间胶囊页一致） */
    .status-board::before {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(120% 78% at 90% -12%,
            color-mix(in oklch, var(--primary) 11%, transparent) 0%, transparent 60%);
        pointer-events: none;
        z-index: 0;
    }
    .status-board > * {
        position: relative;
        z-index: 1;
    }
    :root.dark .status-board {
        --status-text: rgb(240 240 242);
        --status-muted: rgb(202 202 210);
        --status-faint: rgb(162 158 170);
        --status-online: oklch(0.75 0.12 155);
        --wg-bg: color-mix(in oklch, var(--primary) 7%, var(--card-bg));
        --wg-line: color-mix(in oklch, var(--line-divider) 65%, transparent);
    }

    /* ── 头部 ── */
    .status-head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1.15rem;
    }
    .status-head-copy h1 {
        margin: 0;
        font-family: var(--wg-serif);
        font-size: clamp(1.55rem, 3vw, 2.15rem);
        font-weight: 600;
        letter-spacing: -0.01em;
        line-height: 1.1;
        color: var(--status-text);
    }
    .status-head-copy p {
        margin: 0.45rem 0 0;
        max-width: 40rem;
        color: var(--status-muted);
        font-size: 0.92rem;
        line-height: 1.65;
    }
    .status-head-actions {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 0.45rem;
        flex: 0 0 auto;
    }
    .status-refresh {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.42rem 0.9rem;
        border-radius: 999px;
        color: var(--primary);
        background: var(--btn-regular-bg);
        font-weight: 650;
        font-size: 0.85rem;
        transition: transform 180ms cubic-bezier(0.22, 1, 0.36, 1);
    }
    .status-refresh.is-loading svg {
        animation: status-spin 0.9s linear infinite;
    }
    @keyframes status-spin {
        to { transform: rotate(360deg); }
    }
    .status-head-actions time {
        color: var(--status-faint);
        font-size: 0.74rem;
        font-weight: 600;
        font-variant-numeric: tabular-nums;
        font-family: var(--wg-serif);
        letter-spacing: 0.02em;
    }

    /* ── 控制条：设备 / 日期 ── */
    .status-controls {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        margin-bottom: 1.05rem;
    }
    .status-chips,
    .status-date-tabs {
        display: flex;
        flex-wrap: wrap;
        gap: 0.42rem;
    }
    .status-chips button {
        min-height: 2rem;
        padding: 0.32rem 0.8rem;
        border-radius: 999px;
        border: 1px solid transparent;
        background: var(--btn-regular-bg);
        color: var(--status-muted);
        font-size: 0.82rem;
        font-weight: 650;
        transition: transform 180ms cubic-bezier(0.22, 1, 0.36, 1), color 160ms ease, background-color 160ms ease, border-color 160ms ease;
    }
    .status-chips button.is-active {
        color: var(--primary);
        background: color-mix(in oklch, var(--primary) 12%, var(--card-bg));
        border-color: color-mix(in oklch, var(--primary) 28%, transparent);
    }
    .status-date {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        flex-wrap: wrap;
    }
    .status-date-label {
        font-family: var(--wg-serif);
        font-size: 1rem;
        font-weight: 600;
        color: var(--status-text);
    }
    .status-date-meta {
        font-size: 0.72rem;
        color: var(--status-faint);
    }
    .status-date-tabs button {
        padding: 0.26rem 0.62rem;
        border-radius: 999px;
        background: transparent;
        color: var(--status-muted);
        font-size: 0.76rem;
        font-weight: 620;
        font-variant-numeric: tabular-nums;
        transition: color 160ms ease, background-color 160ms ease;
    }
    .status-date-tabs button.is-active {
        color: var(--primary);
        background: color-mix(in oklch, var(--primary) 12%, var(--card-bg));
    }

    /* ── 小组件网格 ── */
    .status-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 0.85rem;
    }
    .status-history {
        margin-top: 1.05rem;
    }
    .status-history-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-bottom: 0.85rem;
        padding-top: 0.95rem;
        border-top: 1px solid var(--wg-line);
    }
    .status-history-head h2 {
        margin: 0;
        color: var(--status-text);
        font-size: 1rem;
        font-weight: 650;
        line-height: 1.2;
    }
    /* 实时区：四张指标卡一排，「此刻」独占整行 —— 不留空洞 */
    .wg-now { grid-column: 1 / -1; }
    /* 历史区：应用 2 格 + 时间线 3 格并排铺满，等高 */
    .status-history-grid { grid-template-columns: repeat(5, minmax(0, 1fr)); }
    .wg-apps { grid-column: span 2; display: flex; flex-direction: column; }
    .wg-timeline { grid-column: span 3; display: flex; flex-direction: column; }
    .wg-apps .status-app-scroll,
    .wg-timeline .status-timeline-scroll { flex: 1 1 auto; }
    @media (max-width: 900px) {
        .status-grid,
        .status-history-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .wg-now, .wg-apps, .wg-timeline { grid-column: 1 / -1; }
    }
    @media (max-width: 520px) {
        .status-grid,
        .status-history-grid { grid-template-columns: 1fr; }
        .wg-now, .wg-apps, .wg-timeline { grid-column: auto; }
    }

    .wg {
        min-width: 0;
        padding: 1.05rem 1.1rem;
        border-radius: 1rem;
        background: var(--wg-bg);
        border: 1px solid var(--wg-line);
    }
    .wg-top {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        color: var(--status-muted);
        font-size: 0.82rem;
        font-weight: 650;
    }
    .wg-top .wg-icon {
        font-size: 1.1rem;
        color: var(--primary);
        flex: 0 0 auto;
    }
    .wg-sub {
        margin-left: auto;
        color: var(--status-faint);
        font-size: 0.72rem;
        font-weight: 600;
        font-variant-numeric: tabular-nums;
    }

    /* 指标大数字卡 */
    .wg-metric {
        display: flex;
        flex-direction: column;
        gap: 0.65rem;
        min-height: 6.4rem;
    }
    .wg-value {
        display: flex;
        align-items: baseline;
        gap: 0.35rem;
        flex-wrap: wrap;
    }
    .wg-value strong {
        font-family: var(--wg-serif);
        font-size: clamp(1.7rem, 3.4vw, 2.3rem);
        font-weight: 600;
        line-height: 1;
        color: var(--status-text);
        font-variant-numeric: tabular-nums;
        letter-spacing: -0.01em;
    }
    .wg-value em {
        font-style: normal;
        font-size: 0.78rem;
        font-weight: 600;
        color: var(--status-faint);
    }
    /* 「暂无 / --」占位值：缩小、淡化，不要占大数字的位置 */
    .wg-value strong.is-na {
        font-size: 1.05rem;
        font-weight: 600;
        color: var(--status-faint);
        letter-spacing: 0;
    }
    /* 占位时把单位藏掉，避免出现「暂无 bpm」 */
    .wg-value:has(strong.is-na) em {
        display: none;
    }
    /* 在线设备：数字前一颗状态点（替代旧绿点，跟随语义 tone） */
    .wg-online .wg-value strong[data-tone] {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
    }
    .wg-online .wg-value strong[data-tone]::before {
        content: "";
        width: 0.5rem;
        height: 0.5rem;
        border-radius: 999px;
        background: var(--status-faint);
    }
    .wg-online .wg-value strong[data-tone="online"]::before {
        background: var(--status-online);
        box-shadow: 0 0 0 0.2rem color-mix(in oklch, var(--status-online) 20%, transparent);
    }

    /* 此刻 */
    .wg-now {
        display: flex;
        flex-direction: column;
        gap: 0.55rem;
    }
    .wg-now-device {
        margin-left: auto;
        padding: 0.1rem 0.5rem;
        border-radius: 999px;
        background: var(--btn-regular-bg);
        color: var(--status-faint);
        font-size: 0.7rem;
        font-weight: 650;
    }
    .wg-now-desc {
        font-size: 1.02rem;
        font-weight: 640;
        line-height: 1.5;
        color: var(--status-text);
    }
    .wg-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 0.42rem;
    }
    .wg-chips span {
        display: inline-flex;
        align-items: center;
        gap: 0.38rem;
        padding: 0.26rem 0.6rem;
        border-radius: 999px;
        color: var(--status-muted);
        background: color-mix(in oklch, var(--primary) 6%, var(--card-bg));
        border: 1px solid color-mix(in oklch, var(--primary) 12%, transparent);
        font-size: 0.78rem;
        font-weight: 620;
    }
    .wg-chips span[data-tone]::before {
        content: "";
        width: 0.44rem;
        height: 0.44rem;
        border-radius: 999px;
        background: var(--status-faint);
    }
    .wg-chips span[data-tone="online"] {
        color: var(--status-online);
        border-color: color-mix(in oklch, var(--status-online) 28%, transparent);
        background: color-mix(in oklch, var(--status-online) 8%, var(--card-bg));
    }
    .wg-chips span[data-tone="online"]::before {
        background: var(--status-online);
        box-shadow: 0 0 0 0.15rem color-mix(in oklch, var(--status-online) 22%, transparent);
    }

    /* 今日应用 */
    .status-app-scroll {
        max-height: 15.5rem;
        overflow-y: auto;
        margin-top: 0.85rem;
        scrollbar-width: thin;
        scrollbar-color: color-mix(in oklch, var(--primary) 36%, transparent) transparent;
    }
    .status-app-scroll,
    .status-timeline-scroll {
        --status-scroll-thumb: color-mix(in oklch, var(--primary) 34%, transparent);
        --status-scroll-thumb-hover: color-mix(in oklch, var(--primary) 48%, transparent);
        --status-scroll-thumb-active: color-mix(in oklch, var(--primary) 62%, transparent);
    }
    .status-app-scroll::-webkit-scrollbar,
    .status-timeline-scroll::-webkit-scrollbar {
        width: 0.34rem;
        height: 0.34rem;
    }
    .status-app-scroll::-webkit-scrollbar-track,
    .status-timeline-scroll::-webkit-scrollbar-track {
        background: transparent;
    }
    .status-app-scroll::-webkit-scrollbar-thumb,
    .status-timeline-scroll::-webkit-scrollbar-thumb {
        border-radius: 999px;
        background: var(--status-scroll-thumb);
    }
    .status-app-scroll::-webkit-scrollbar-thumb:hover,
    .status-timeline-scroll::-webkit-scrollbar-thumb:hover {
        background: var(--status-scroll-thumb-hover);
    }
    .status-app-scroll::-webkit-scrollbar-thumb:active,
    .status-timeline-scroll::-webkit-scrollbar-thumb:active {
        background: var(--status-scroll-thumb-active);
    }
    .status-app-list {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }
    .status-app-row {
        display: flex;
        flex-direction: column;
        gap: 0.28rem;
    }
    .status-app-top {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 0.6rem;
    }
    .status-app-name {
        font-weight: 640;
        font-size: 0.9rem;
        color: var(--status-text);
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    .status-app-time {
        flex: 0 0 auto;
        color: var(--status-muted);
        font-size: 0.82rem;
        font-weight: 600;
        font-variant-numeric: tabular-nums;
        font-family: var(--wg-serif);
    }
    .status-app-detail {
        font-size: 0.72rem;
        color: var(--status-faint);
    }
    .status-app-track {
        height: 0.5rem;
        margin-top: 0.15rem;
        border-radius: 999px;
        background: color-mix(in oklch, var(--primary) 10%, var(--card-bg));
        overflow: hidden;
    }
    .status-app-track span {
        display: block;
        height: 100%;
        width: var(--ratio, 0%);
        border-radius: 999px;
        background: linear-gradient(90deg,
            color-mix(in oklch, var(--primary) 78%, var(--card-bg)),
            var(--primary));
    }

    /* 今日足迹（时间线） */
    .status-timeline-scroll {
        max-height: 24rem;
        overflow-y: auto;
        margin-top: 0.85rem;
        scrollbar-width: thin;
        scrollbar-color: color-mix(in oklch, var(--primary) 36%, transparent) transparent;
    }
    .status-timeline-list {
        display: flex;
        flex-direction: column;
        gap: 0;
        margin: 0;
        padding: 0;
        list-style: none;
    }
    .status-timeline-item {
        display: grid;
        grid-template-columns: 3.1rem minmax(0, 1fr) auto;
        gap: 0.7rem;
        align-items: baseline;
        padding: 0.6rem 0;
    }
    .status-timeline-item + .status-timeline-item {
        border-top: 1px solid color-mix(in oklch, var(--line-divider) 45%, transparent);
    }
    .status-timeline-time {
        color: var(--primary);
        font-size: 0.82rem;
        font-weight: 650;
        font-variant-numeric: tabular-nums;
        font-family: var(--wg-serif);
    }
    .status-timeline-main {
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
    }
    .status-timeline-main strong {
        font-weight: 620;
        font-size: 0.9rem;
        color: var(--status-text);
        line-height: 1.4;
    }
    .status-timeline-main span {
        font-size: 0.74rem;
        color: var(--status-faint);
    }
    .status-timeline-app {
        flex: 0 0 auto;
        align-self: center;
        padding: 0.16rem 0.5rem;
        border-radius: 999px;
        background: color-mix(in oklch, var(--primary) 8%, var(--card-bg));
        color: var(--status-muted);
        font-size: 0.7rem;
        font-weight: 620;
        white-space: nowrap;
    }
    .status-empty-note {
        padding: 0.4rem 0;
        color: var(--status-muted);
