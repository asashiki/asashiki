function setAiState(root: HTMLElement, state: "error" | "loading" | "ready", label: string) {
	const badge = root.querySelector<HTMLElement>("[data-ai-thinking]");
	if (!badge) return;
	badge.classList.toggle("is-error", state === "error");
	badge.classList.toggle("is-ready", state === "ready");
	setText(badge, "[data-ai-state]", label);
}

function setAiSummary(root: HTMLElement, text: string, typing = false) {
	const summary = root.querySelector<HTMLElement>("[data-ai-summary]");
	if (!summary) return;
	summary.textContent = text;
	summary.classList.toggle("is-typing", typing);
}

function cleanAiText(raw: string) {
	return raw
		.replace(/<think>[\s\S]*?<\/think>/gi, "")
		.replace(/```[\s\S]*?```/g, (block) => block.replace(/```/g, ""))
		.replace(/^\s*(final answer|最终答案)\s*[:：]/i, "")
		.trim();
}

function aiCacheKey() {
	return `${AI_SESSION_PREFIX}${todayShanghai()}`;
}

function readAiCache(key: string) {
	try {
		return window.sessionStorage.getItem(key);
	} catch {
		return null;
	}
}

function writeAiCache(key: string, value: string) {
	try {
		window.sessionStorage.setItem(key, value);
	} catch {
		// Session storage can be unavailable in strict privacy modes.
	}
}

function stopAiTyping(store: StatusStore) {
	if (store.aiTypingTimer) {
		window.clearInterval(store.aiTypingTimer);
		store.aiTypingTimer = null;
	}
}

function typeAiSummary(root: HTMLElement, text: string) {
	const store = getStore(root);
	stopAiTyping(store);
	const summary = root.querySelector<HTMLElement>("[data-ai-summary]");
	if (!summary) return;
	summary.textContent = "";
	summary.classList.add("is-typing");
	let index = 0;
	store.aiTypingTimer = window.setInterval(() => {
		const step = text.charCodeAt(index) > 255 ? 2 : 3;
		index = Math.min(text.length, index + step);
		summary.textContent = text.slice(0, index);
		if (index >= text.length) {
			stopAiTyping(store);
			summary.classList.remove("is-typing");
			setAiState(root, "ready", "已生成");
		}
	}, 34);
}

function appSummarySnapshot(root: HTMLElement) {
	const store = getStore(root);
	const dayLabel = relativeDateLabel(store.timelineDate);
	const rows = timelineRowsForStore(store);
	const active = activityForSelectedDate(store);
	const apps = (active?.result.data?.perApp || [])
		.filter((item) => !QUIET_TIMELINE_APP_IDS.has(item.appId || ""))
		.filter((item) => (item.totalSeconds || 0) > 0)
		.sort((a, b) => (b.totalSeconds || 0) - (a.totalSeconds || 0));
	const selected = primaryDevice(store.devices, store.selectedDevice);
	const onlineDevices = store.devices.filter((item) => item.isOnline);
	const currentApps = store.devices
		.filter((item) => item.appId)
		.sort((a, b) => timestamp(b.lastSeenAt) - timestamp(a.lastSeenAt))
		.slice(0, 6)
		.map((item) => ({
			app: appName(item.appId),
			device: item.deviceName || item.deviceId || "设备",
			isOnline: Boolean(item.isOnline),
			lastSeen: timeAgo(item.lastSeenAt),
			title: item.windowTitle ? truncate(item.windowTitle, 54) : "",
		}));
	const recentTimeline = rows.slice(0, 8).map((item) => ({
		app: appName(item.appId),
		device: store.devices.find((device) => device.deviceId === item.deviceId)?.deviceName || item.deviceId || "设备",
		duration: formatDuration(item.durationSeconds || 0),
		time: formatClock(item.startedAt),
		title: item.windowTitle ? truncate(item.windowTitle, 54) : "",
	}));
	const topApps = apps.slice(0, 6).map((item) => ({
		app: appName(item.appId),
		count: item.count || 0,
		time: formatDuration(item.totalSeconds || 0),
	}));
	return {
		day: `${dayLabel} ${store.timelineDate}`,
		generatedAt: nowShanghaiStamp(),
		online: `${onlineDevices.length}/${store.devices.length}`,
		selectedDevice: selected?.deviceName || selected?.deviceId || "总览",
		currentApps,
		recentTimeline,
		timelineCount: rows.length,
		topApps,
	};
}

function buildAiPrompt(root: HTMLElement) {
	const snapshot = appSummarySnapshot(root);
	return [
		"你在为 asashiki.com 的“状态”页面生成状态小结。",
		"只根据下面的 app/设备使用快照写，不要编造天气、位置、健康、资产、日记原文等信息。",
		"输出要求：中文，50-90 个汉字，1-2 句；语气轻松、可爱一点，但不要营销腔；可以在结尾自然加“喵~”。",
		"不要输出标题、项目符号、JSON、Markdown，也不要输出 thinking 或推理过程。",
		`页面打开时的快照：${JSON.stringify(snapshot)}`,
	].join("\n");
}

async function postAiPrompt(prompt: string): Promise<ApiResult<AiProxyResponse>> {
	let timer = 0;
	try {
		const controller = new AbortController();
		timer = window.setTimeout(() => controller.abort(), AI_TIMEOUT);
		const response = await fetch(AI_PROXY_URL, {
			body: JSON.stringify({ prompt }),
			headers: { "Content-Type": "application/json" },
			method: "POST",
			signal: controller.signal,
		});
		const data = (await response.json().catch(() => null)) as AiProxyResponse | null;
		if (!response.ok) {
			return {
				data,
				error: data?.error || data?.detail || `AI 代理返回 ${response.status}`,
				ok: false,
				status: response.status,
			};
		}
		return { data, ok: true, status: response.status };
	} catch (error) {
		return { data: null, error: error instanceof Error ? error.message : String(error), ok: false };
	} finally {
		if (timer) window.clearTimeout(timer);
	}
}

async function startAiSummary(root: HTMLElement) {
	const store = getStore(root);
	const key = aiCacheKey();
	if (store.aiCacheKey && store.aiCacheKey !== key) {
		store.aiRequested = false;
	}
	const cached = readAiCache(key);
	store.aiCacheKey = key;

	if (cached) {
		store.aiRequested = true;
		stopAiTyping(store);
		setAiState(root, "ready", "会话缓存");
		setAiSummary(root, cached);
		return;
	}

	if (store.aiRequested) return;
	store.aiRequested = true;
	setAiState(root, "loading", "总结中");
	setAiSummary(root, "正在把刚刚读到的 app 状态揉成一句轻轻的小结。", true);

	let result: ApiResult<AiProxyResponse>;
	try {
		result = await postAiPrompt(buildAiPrompt(root));
	} catch (error) {
		result = { data: null, error: error instanceof Error ? error.message : String(error), ok: false };
	}
	if (store.aiCacheKey !== key || !document.body.contains(root)) return;

	if (!result.ok || !result.data?.text) {
		const message = result.error || result.data?.error || result.data?.detail || "AI 小结暂时没有回来。";
		stopAiTyping(store);
		setAiState(root, "error", "生成失败");
		setAiSummary(root, `小结暂时生成失败：${message}`);
		store.aiRequested = false;
		return;
	}

	const text = cleanAiText(result.data.text);
	const finalText = text || "今天的 app 状态有点安静，先让页面保持轻轻在线喵~";
	writeAiCache(key, finalText);
	typeAiSummary(root, finalText);
}

async function loadStatus(root: HTMLElement) {
	const store = getStore(root);
	const seq = store.loadSeq + 1;
	store.loadSeq = seq;
	const refresh = root.querySelector<HTMLButtonElement>("[data-status-refresh]");
	refresh?.classList.add("is-loading");
	refresh?.setAttribute("aria-busy", "true");
	for (const name of ["timeline", "activity", "body", "service", "steam"]) {
		setPanelState(root, name, "loading", "读取中。");
	}

	try {
		const dates = recentDates();
		const [health, devices, timeline, activity, weather, connectors, archive, steam, stepsRecords, heartRecords, sleepRecords] = await Promise.all([
			getJson<HealthResponse>("/health"),
			getJson<DevicesResponse>("/api/devices/current"),
			getRecentBundle<TimelineResponse>(dates, (date) => `/api/devices/timeline-query?date=${date}&limit=120`, (data) => Boolean(data?.activities?.length)),
			getRecentBundle<ActivityResponse>(dates, (date) => `/api/devices/activity-summary?date=${date}`, (data) => Boolean(data?.perApp?.some((item) => (item.totalSeconds || 0) > 0))),
			getJson<WeatherResponse>("/api/weather"),
			getJson<ConnectorsSummary>("/api/connectors/summary"),
			getJson<ArchiveStatus>("/api/archive/status"),
			getJson<SteamProfile>("/api/steam/profile"),
			getJson<HealthRecordsResponse>("/api/devices/health-records?type=steps&limit=160"),
			getJson<HealthRecordsResponse>("/api/devices/health-records?type=heart_rate&limit=40"),
			getJson<HealthRecordsResponse>("/api/devices/health-records?type=sleep&limit=30"),
		]);

		if (seq !== store.loadSeq || !document.body.contains(root)) return;

		const apiOnline = health.ok && health.data?.status === "ok";
		setText(root, "[data-api-state]", apiOnline ? "Core API 在线" : "Core API 未响应");
		root.querySelector("[data-api-pulse]")?.classList.toggle("is-error", !apiOnline);
		setText(
			root,
			"[data-updated-at]",
			new Intl.DateTimeFormat("zh-CN", {
				hour: "2-digit",
				minute: "2-digit",
				second: "2-digit",
				timeZone: "Asia/Shanghai",
			}).format(new Date()),
		);

		store.devices = devices.ok ? devices.data?.devices || [] : [];
		if (store.selectedDevice !== "all" && !store.devices.some((item) => item.deviceId === store.selectedDevice)) {
			store.selectedDevice = "all";
			store.timelineVisible = timelinePageSize();
		}
		const previousTimelineDate = store.timelineDate;
		store.timeline = timeline;
		store.timelineDate = timeline.results.some((item) => item.date === previousTimelineDate) ? previousTimelineDate : timeline.activeDate;
		if (store.timelineDate !== previousTimelineDate) store.timelineVisible = timelinePageSize();
		store.stepsRecords = stepsRecords;
		store.heartRecords = heartRecords;
		store.sleepRecords = sleepRecords;
		store.lastLoadedAt = Date.now();

		renderWeather(root, weather);
		renderHealth(root);
		renderNow(root);
		renderActivity(root, activity);
		renderTimeline(root);
		renderService(root, health, connectors, archive);
		renderSteam(root, steam);
		syncTimelineHeight(root);
		startAiSummary(root);
	} catch (error) {
		if (seq !== store.loadSeq) return;
		const message = error instanceof Error ? error.message : String(error);
		setText(root, "[data-api-state]", "状态读取异常");
		root.querySelector("[data-api-pulse]")?.classList.add("is-error");
		for (const name of ["timeline", "activity", "body", "service", "steam"]) {
			setPanelState(root, name, "error", `读取失败：${message}`);
		}
	} finally {
		if (seq === store.loadSeq) {
			refresh?.classList.remove("is-loading");
			refresh?.removeAttribute("aria-busy");
		}
	}
}

function initStatusPage() {
	document.querySelectorAll<HTMLElement>("[data-status-page]").forEach((root) => {
		const store = getStore(root);
		if (root.dataset.statusBound) {
			syncTimelineHeight(root);
			if (!store.lastLoadedAt || Date.now() - store.lastLoadedAt > 15_000) {
				loadStatus(root);
			}
			return;
		}
		root.dataset.statusBound = "true";
		root.querySelector("[data-status-refresh]")?.addEventListener("click", () => loadStatus(root));
		root.querySelector("[data-timeline-scroll]")?.addEventListener("scroll", (event) => {
			const scroll = event.currentTarget as HTMLElement;
			if (scroll.scrollTop + scroll.clientHeight >= scroll.scrollHeight - 96) appendTimeline(root);
		});
		const resizeHandler = () => syncTimelineHeight(root);
		store.resizeHandler = resizeHandler;
		window.addEventListener("resize", resizeHandler);
		loadStatus(root);
		store.refreshTimer = window.setInterval(() => {
			if (!document.body.contains(root)) {
				const latest = getStore(root);
				delete root.dataset.statusBound;
				stopAiTyping(latest);
				window.removeEventListener("resize", resizeHandler);
				if (latest.refreshTimer) window.clearInterval(latest.refreshTimer);
				latest.refreshTimer = null;
				return;
			}
			loadStatus(root);
		}, REFRESH_INTERVAL);
	});
}

if (document.readyState === "loading") {
	document.addEventListener("DOMContentLoaded", initStatusPage, { once: true });
} else {
	initStatusPage();
}

window.addEventListener("pageshow", initStatusPage);
document.addEventListener("astro:page-load", initStatusPage);

const setupStatusSwup = () => {
	window.swup?.hooks?.on("page:view", initStatusPage);
	window.swup?.hooks?.on("content:replace", initStatusPage);
};

if (window.swup?.hooks) {
	setupStatusSwup();
} else {
	document.addEventListener("swup:enable", setupStatusSwup);
}
</script>
