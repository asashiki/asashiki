        min-height: 22.4rem;
        background:
            linear-gradient(160deg, color-mix(in oklch, var(--primary) 10%, transparent), transparent 58%),
            color-mix(in oklch, var(--card-bg) 50%, transparent);
    }

    .ai-link-runway {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.75rem;
        border-radius: 1.35rem;
        padding: 0.85rem;
    }

    .ai-source-link {
        display: grid;
        gap: 0.25rem;
        border-radius: 1rem;
        padding: 0.85rem 0.95rem;
        color: var(--text-regular);
        background: color-mix(in oklch, var(--card-bg) 46%, transparent);
        transition: transform 200ms cubic-bezier(0.22, 1, 0.36, 1), background-color 180ms ease;
    }

    .ai-source-link span {
        color: var(--primary);
        font-weight: 800;
    }

    .ai-source-link small {
        color: color-mix(in oklch, currentColor 54%, transparent);
        line-height: 1.25rem;
    }

    .ai-details-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 0.85rem;
        align-items: start;
    }

    .ai-detail-card {
