        text-align: left;
        background: color-mix(in oklch, var(--card-bg) 48%, transparent);
        border: 1px dashed var(--line-divider);
        cursor: pointer;
        transition: transform 220ms cubic-bezier(0.22, 1, 0.36, 1), background-color 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
    }

    .ai-award-card::before {
        position: absolute;
        inset: auto 1rem 1rem auto;
        width: 3.4rem;
        height: 3.4rem;
        border-radius: 999px;
        background: radial-gradient(circle, color-mix(in oklch, var(--primary) 18%, transparent), transparent 68%);
        opacity: 0;
        transform: scale(0.8);
        transition: transform 220ms cubic-bezier(0.22, 1, 0.36, 1), opacity 180ms ease;
        content: "";
        pointer-events: none;
    }

    .ai-award-card.is-selected {
        background:
            linear-gradient(135deg, color-mix(in oklch, var(--primary) 14%, transparent), transparent 58%),
