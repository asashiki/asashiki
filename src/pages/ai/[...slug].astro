        pointer-events: none;
        transition: transform 240ms cubic-bezier(0.22, 1, 0.36, 1), opacity 180ms ease, background-color 180ms ease, border-color 180ms ease;
    }

    .ai-feature-flow.is-active {
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
    }

    .ai-feature-index,
    .ai-feature-value {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        color: var(--primary);
        background: var(--btn-regular-bg);
