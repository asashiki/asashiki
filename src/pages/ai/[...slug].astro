    }

    .ai-audio-style-disc .ai-sound-shell::after {
        inset: 3.25rem;
        border-style: solid;
        opacity: 0.45;
    }

    .ai-audio-style-save {
        width: min(100%, 18.5rem);
    }

    .ai-audio-style-save .ai-sound-shell {
        min-height: auto;
        display: grid;
        grid-template-columns: 4.75rem minmax(0, 1fr) auto;
        gap: 0.85rem;
        align-items: center;
        place-items: stretch;
        border-radius: 1.35rem;
        padding: 0.85rem;
        background:
            linear-gradient(135deg, color-mix(in oklch, var(--card-bg) 68%, transparent), color-mix(in oklch, var(--btn-plain-bg-hover) 82%, transparent)) padding-box,
            linear-gradient(135deg, color-mix(in oklch, var(--primary) 46%, white), transparent 58%) border-box;
        box-shadow:
            inset 0 0 0 1px color-mix(in oklch, var(--card-bg) 52%, transparent),
            0 0.85rem 2rem color-mix(in oklch, var(--primary) 12%, transparent);
    }

    .ai-sound-button {
        position: relative;
        width: 6rem;
        height: 6rem;
        color: var(--primary);
        border-radius: 999px;
        background: var(--btn-regular-bg);
        transition: transform 220ms cubic-bezier(0.22, 1, 0.36, 1), background-color 180ms ease;
    }

    .ai-sound-cover {
