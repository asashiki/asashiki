---
import path from "node:path";
import ImageWrapper from "@components/misc/ImageWrapper.astro";
import PostMetadata from "@components/PostMeta.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import {
	type AiVisualAward,
	type AiVisualPage,
	getAiVisualPageUrl,
	getAllAiVisualPages,
} from "@utils/ai-visual-utils";
import { getSortedPosts } from "@utils/content-utils";
import { getDir, getPostUrlBySlug } from "@utils/url-utils";
import { Icon } from "astro-icon/components";

export async function getStaticPaths() {
	const posts = await getSortedPosts();
	const postMap = new Map(posts.map((post) => [post.slug, post]));

	return getAllAiVisualPages().map((visualPage) => ({
		params: { slug: visualPage.slug },
		props: {
			visualPage,
			entry: postMap.get(visualPage.slug),
		},
	}));
}

const { visualPage, entry } = Astro.props as {
	visualPage: AiVisualPage;
	entry?: Awaited<ReturnType<typeof getSortedPosts>>[number];
};

const sourceTitle = entry?.data.title || visualPage.title;
const sourceUrl = getPostUrlBySlug(visualPage.slug);
const pageTitle = `${sourceTitle} · AI增强阅读`;
const coverBasePath = entry?.id
	? path.join("content/posts/", getDir(entry.id))
	: "/";
const audioCover = visualPage.audio?.cover || entry?.data.image || "";
const audioMetingId =
	visualPage.audio?.metingId ||
	visualPage.audio?.songId ||
	visualPage.audio?.neteaseId ||
	"";
const audioServer = visualPage.audio?.server || "netease";
const audioProvider =
	visualPage.audio?.provider ?? (audioMetingId ? "meting" : "audio");
const hasAudioSource = !!(audioMetingId || visualPage.audio?.src);
const audioStyle = visualPage.audio?.style || "disc";
const collectionItemLabel = visualPage.collectionItemLabel || "箱";
const collectionTitle = visualPage.collectionTitle || "纸箱奖展柜";
const awardsPerPage = visualPage.collectionPerPage || 3;
const collectionDescription =
	visualPage.collectionDescription ||
	`完整收录 ${visualPage.awards?.length || 0} 项，每次打开一${collectionItemLabel}。`;
const awardGroups: { award: AiVisualAward; index: number }[][] = [];
for (
	let index = 0;
	index < (visualPage.awards?.length || 0);
	index += awardsPerPage
) {
	awardGroups.push(
		(visualPage.awards?.slice(index, index + awardsPerPage) || []).map(
			(award, groupIndex) => ({ award, index: index + groupIndex }),
		),
	);
}
const firstAward = visualPage.awards?.[0];
const pageClass = [
	"card-base ai-visual-page z-10 px-5 md:px-8 pt-5 pb-7 relative w-full max-w-[100vw]",
	visualPage.variant ? `ai-variant-${visualPage.variant}` : "",
];
---

<MainGridLayout title={pageTitle} description={visualPage.subtitle} lang={entry?.data.lang} setOGTypeArticle={true}>
    <div class="flex w-full max-w-[100vw] rounded-[var(--radius-large)] overflow-hidden relative mb-4">
        <article class:list={pageClass}>
            <div class="ai-visual-wash pointer-events-none absolute inset-x-0 top-0 h-56"></div>

            <div class="relative onload-animation">
                <div class="flex flex-wrap items-center gap-2 text-sm text-50 mb-4">
                    <a href={sourceUrl} class="btn-regular rounded-lg h-8 px-3 gap-2 active:scale-95">
                        <Icon name="material-symbols:arrow-back-rounded" class="text-lg"></Icon>
                        原文
                    </a>
                    <span class="rounded-lg h-8 px-3 inline-flex items-center bg-[var(--btn-plain-bg-hover)] text-[var(--btn-content)] font-medium">
                        AI增强阅读模式
                    </span>
                    <span class="rounded-lg h-8 px-3 inline-flex items-center bg-[var(--btn-plain-bg-hover)] text-50">
                        {visualPage.tone}
                    </span>
                </div>

                <section class="ai-hero-stage relative mb-8 rounded-[1.6rem] px-4 py-5 md:px-7 md:py-7">
                    <div class="ai-hero-grid">
                        <div class="min-w-0">
                            <div class="relative mb-5 pl-4 md:pl-5 before:absolute before:left-0 before:top-2 before:h-10 before:w-1 before:rounded-md before:bg-[var(--primary)]">
                                <h1 class="text-3xl md:text-[2.55rem]/[3rem] font-bold text-90 mb-3">
                                    {sourceTitle}
                                </h1>
                                <p class="text-75 text-base md:text-lg leading-8 max-w-3xl">
                                    {visualPage.subtitle}
                                </p>
                            </div>

                            {entry && <PostMetadata
                                class="mb-5"
                                published={entry.data.published}
                                updated={entry.data.updated}
                                tags={entry.data.tags}
                                category={entry.data.category}
                            ></PostMetadata>}

                            <p class="ai-lead-line text-75 leading-8 m-0">
                                {visualPage.lead}
                            </p>
                        </div>

                        {visualPage.audio && <div class:list={["ai-sound-orbit ai-audio-chip", `ai-audio-style-${audioStyle}`, {"has-audio": hasAudioSource}]}>
                            <div class="ai-sound-shell">
                                <button
                                    class="ai-audio-toggle ai-sound-button active:scale-95"
                                    type="button"
                                    aria-label={`播放 ${visualPage.audio.title}`}
                                    data-has-audio={String(hasAudioSource)}
                                    data-audio-provider={audioProvider}
                                    data-audio-src={visualPage.audio.src || ""}
                                    data-meting-id={audioMetingId}
                                    data-meting-server={audioServer}
                                    data-audio-title={visualPage.audio.title}
                                    data-audio-artist={visualPage.audio.artist || ""}
                                    data-audio-cover={audioCover}
                                >
                                    <span class="ai-sound-cover">
                                        {audioCover
                                            ? <ImageWrapper src={audioCover} basePath={coverBasePath} alt={visualPage.audio.title} class="h-full w-full"></ImageWrapper>
                                            : <span class="h-full w-full flex items-center justify-center text-[var(--primary)]"><Icon name="material-symbols:music-note-rounded" class="text-2xl"></Icon></span>}
                                    </span>
                                    <span class="ai-sound-play">
                                        <Icon class="ai-audio-play text-2xl" name="material-symbols:play-arrow-rounded"></Icon>
                                        <Icon class="ai-audio-pause hidden text-2xl" name="material-symbols:pause-rounded"></Icon>
                                        <Icon class="ai-audio-loading hidden text-2xl" name="material-symbols:graphic-eq-rounded"></Icon>
                                    </span>
                                    <span class="sr-only ai-audio-label">{hasAudioSource ? "播放" : "待配置"}</span>
                                </button>
                                {audioStyle !== "disc" && <div class="ai-sound-copy">
                                    <div class="text-50 text-xs">{visualPage.audio.kicker || "BGM"}</div>
                                    <div class="text-90 font-bold leading-6">{visualPage.audio.title}</div>
                                    {visualPage.audio.artist && <div class="text-50 text-sm">{visualPage.audio.artist}</div>}
                                </div>}
                                <div class="ai-sound-bars" aria-hidden="true">
                                    <span></span><span></span><span></span><span></span>
                                </div>
                            </div>
                        </div>}
                    </div>

                    <div class="ai-metric-ribbon mt-6">
                        {visualPage.metrics.map((metric) => (
                            <div class="ai-metric-token">
                                <div class="text-50 text-xs mb-1">{metric.label}</div>
                                <div class="text-[var(--primary)] text-2xl font-bold leading-7">{metric.value}</div>
                                {metric.detail && <div class="text-50 text-xs leading-5 mt-1">{metric.detail}</div>}
                            </div>
                        ))}
                    </div>
                </section>
            </div>

            {visualPage.statBars && <section class="ai-section ai-statboard ai-reveal relative mb-9" data-ai-statboard style="animation-delay: calc(var(--content-delay) + 100ms);">
                <div class="ai-section-heading">
                    <Icon name="material-symbols:bar-chart-rounded" class="text-[var(--primary)] text-2xl"></Icon>
                    <h2 class="text-2xl font-bold text-90">年度计量</h2>
                </div>
                <div class="ai-stat-grid">
                    {visualPage.statBars.map((stat, index) => (
                        <button
                            class:list={["ai-stat-bar", {"is-active": index === 0}]}
                            type="button"
                            data-stat-bar={index}
                            style={`--stat-ratio: ${Math.max(0, Math.min(1, stat.ratio))};`}
                        >
                            <span class="ai-stat-top">
                                <span>{stat.label}</span>
                                <strong>{stat.value}</strong>
                            </span>
                            <span class="ai-stat-track"><span></span></span>
                            {stat.detail && <span class="ai-stat-detail">{stat.detail}</span>}
                        </button>
                    ))}
                </div>
            </section>}

            {visualPage.featureCards && <section class="ai-section ai-feature-tabs ai-reveal relative mb-9" data-ai-feature-tabs style="animation-delay: calc(var(--content-delay) + 125ms);">
                <div class="ai-section-heading">
                    <Icon name="material-symbols:graphic-eq-rounded" class="text-[var(--primary)] text-2xl"></Icon>
                    <h2 class="text-2xl font-bold text-90">{visualPage.featureTitle || "观看切面"}</h2>
                </div>
                <div class="ai-feature-board">
                    <div class="ai-feature-switches" role="tablist" aria-label={visualPage.featureTitle || "观看切面"}>
                        {visualPage.featureCards.map((card, index) => (
                            <button
                                class:list={["ai-feature-switch", {"is-active": index === 0}]}
                                type="button"
                                role="tab"
                                aria-selected={index === 0 ? "true" : "false"}
                                data-feature-tab={index}
                            >
                                <span>{String(index + 1).padStart(2, "0")}</span>
                                <strong>{card.title}</strong>
                            </button>
                        ))}
                    </div>
                    <div class="ai-feature-river">
                    {visualPage.featureCards.map((card, index) => (
                        <div class:list={["ai-feature-flow", {"is-active": index === 0}]} data-feature-panel={index} aria-hidden={index === 0 ? "false" : "true"} style={`--flow-offset: ${index % 2 ? "1.4rem" : "0rem"};`}>
                            <div class="ai-feature-index">{String(index + 1).padStart(2, "0")}</div>
                            <div class="min-w-0">
                                <div class="text-50 text-sm mb-1">{card.label}</div>
                                <h3 class="text-xl font-bold text-90 mb-2">{card.title}</h3>
                                <p class="text-75 leading-7 m-0">{card.description}</p>
                            </div>
                            {card.value && <div class="ai-feature-value">{card.value}</div>}
                        </div>
                    ))}
                    </div>
                </div>
            </section>}

            {visualPage.jumpLinks && <nav class="ai-link-runway ai-reveal relative mb-9" aria-label="原文跳转">
                {visualPage.jumpLinks.map((link) => (
                    <a href={`${sourceUrl}#${link.fragment}`} class="ai-source-link">
                        <span>{link.label}</span>
                        {link.description && <small>{link.description}</small>}
                    </a>
                ))}
            </nav>}

            <section class="ai-section ai-reveal relative mb-9" style="animation-delay: calc(var(--content-delay) + 200ms);">
                <div class="ai-section-heading">
                    <Icon name="material-symbols:map-outline-rounded" class="text-[var(--primary)] text-2xl"></Icon>
                    <h2 class="text-2xl font-bold text-90">{visualPage.mapTitle || "记忆地图"}</h2>
                </div>
                <div class="ai-memory-map">
                    {visualPage.memoryNodes.map((node, index) => (
                        <div class="ai-node" style={`--node-color: ${node.accent || "var(--primary)"}; --node-index: ${index};`}>
                            <div class="ai-node-pin"></div>
                            <span class="ai-node-label">{node.label}</span>
                            <h3 class="text-lg font-bold text-90 mb-2">{node.title}</h3>
                            <p class="text-75 leading-7 m-0">{node.description}</p>
                        </div>
                    ))}
                </div>
            </section>

            {visualPage.awards && <section id="ai-collection" class="ai-section ai-awards ai-reveal relative mb-9" data-ai-awards data-collection-variant={visualPage.variant || "default"} style="animation-delay: calc(var(--content-delay) + 250ms);">
                <div class="ai-awards-header">
                    <div class="ai-section-heading mb-0">
                        <Icon name="material-symbols:trophy-outline-rounded" class="text-[var(--primary)] text-2xl"></Icon>
                        <div>
                            <h2 class="text-2xl font-bold text-90">{collectionTitle}</h2>
                            <p class="text-50 text-sm leading-6 m-0">{collectionDescription}</p>
                        </div>
                    </div>
                    <div class="ai-awards-controls">
                        <button class="ai-award-prev" type="button" aria-label={`上一${collectionItemLabel}`}>
                            <Icon name="material-symbols:chevron-left-rounded" class="text-2xl"></Icon>
                        </button>
                        <span class="ai-award-status" data-award-status>1 / {awardGroups.length}</span>
                        <button class="ai-award-next" type="button" aria-label={`下一${collectionItemLabel}`}>
                            <Icon name="material-symbols:chevron-right-rounded" class="text-2xl"></Icon>
                        </button>
                    </div>
                </div>

                <div class="ai-awards-stage">
                    <div class="ai-awards-pages">
                        {awardGroups.map((group, pageIndex) => (
                            <div class:list={["ai-award-page", {"is-active": pageIndex === 0}]} data-award-page={pageIndex} aria-hidden={pageIndex === 0 ? "false" : "true"}>
                                {group.map(({award, index}) => (
                                    <button
                                        class:list={["ai-award-card", {"is-selected": index === 0}]}
                                        type="button"
                                        data-award-card
                                        data-award-index={index}
                                        data-award-title={award.title}
                                        data-award-work={award.work}
                                        data-award-description={award.description || ""}
                                        aria-pressed={index === 0 ? "true" : "false"}
                                        aria-label={`查看 ${award.work}`}
                                        style={`--award-index: ${index % awardsPerPage};`}
                                    >
                                        <span class="ai-award-number">{String(index + 1).padStart(2, "0")}</span>
                                        <span class="ai-award-card-body">
                                            <span class="ai-award-kicker">{award.title}</span>
                                            <strong>{award.work}</strong>
                                            {award.description && <span class="ai-award-excerpt">{award.description}</span>}
                                        </span>
                                        <span class="ai-award-card-cue" aria-hidden="true">
                                            <Icon name="material-symbols:ads-click-rounded" class="text-lg"></Icon>
                                        </span>
                                    </button>
                                ))}
                            </div>
                        ))}
                    </div>

                    <aside class="ai-award-focus" data-award-focus>
                        <div class="ai-award-focus-top">
                            <span data-award-focus-index>01</span>
                            <small>{collectionItemLabel}</small>
                        </div>
                        <div class="ai-award-focus-kicker" data-award-focus-title>{firstAward?.title}</div>
                        <h3 data-award-focus-work>{firstAward?.work}</h3>
                        <p data-award-focus-description hidden={!firstAward?.description}>
                            {firstAward?.description || ""}
                        </p>
                    </aside>
                </div>

                <div class="ai-award-dots" aria-label={`${collectionTitle}分页`}>
                    {awardGroups.map((_, index) => (
                        <button class:list={["ai-award-dot", {"is-active": index === 0}]} type="button" data-award-dot={index} aria-label={`第 ${index + 1} ${collectionItemLabel}`}></button>
                    ))}
                </div>
            </section>}

            <section class="ai-section ai-reveal relative mb-9" style="animation-delay: calc(var(--content-delay) + 300ms);">
                <div class="ai-section-heading">
                    <Icon name="material-symbols:calendar-clock-rounded" class="text-[var(--primary)] text-2xl"></Icon>
                    <h2 class="text-2xl font-bold text-90">{visualPage.timelineTitle || "时间线"}</h2>
                </div>
                <div class="ai-timeline-rail">
                    {visualPage.timeline.map((item, index) => (
                        <div class="ai-timeline-item" style={`--timeline-index: ${index};`}>
                            <div class="ai-timeline-time">{item.time}</div>
                            <div>
                                <div class="text-90 font-bold mb-1">{item.title}</div>
                                <p class="text-75 leading-7 m-0">{item.description}</p>
                            </div>
                        </div>
                    ))}
                </div>
            </section>

            {visualPage.detailPanels && <section class="ai-section ai-detail-panels ai-reveal relative mb-9" style="animation-delay: calc(var(--content-delay) + 325ms);">
                <div class="ai-section-heading">
                    <Icon name="material-symbols:inventory-2-outline-rounded" class="text-[var(--primary)] text-2xl"></Icon>
                    <h2 class="text-2xl font-bold text-90">存档夹</h2>
                </div>
                <div class="ai-details-grid">
                    {visualPage.detailPanels.map((panel, index) => (
                        <details class="ai-detail-card" open={index === 0}>
                            <summary>
                                <span>{panel.label}</span>
                                <strong>{panel.title}</strong>
                                <Icon name="material-symbols:expand-more-rounded" class="text-2xl"></Icon>
                            </summary>
                            <p class="text-75 leading-7 m-0">{panel.description}</p>
                            {panel.items && <ul>
                                {panel.items.map((item) => <li>{item}</li>)}
                            </ul>}
                        </details>
                    ))}
                </div>
            </section>}

            {visualPage.copyBlock && <section class="ai-copy-panel ai-reveal relative mb-9">
                <div class="ai-copy-head">
                    <div>
                        {visualPage.copyBlock.label && <div class="text-50 text-sm mb-1">{visualPage.copyBlock.label}</div>}
                        <h2 class="text-2xl font-bold text-90 m-0">{visualPage.copyBlock.title}</h2>
                    </div>
                    <button class="ai-copy-button" type="button" data-copy-text={visualPage.copyBlock.content}>
                        <Icon name="material-symbols:content-copy-outline-rounded" class="text-xl"></Icon>
                        <span>{visualPage.copyBlock.buttonLabel || "复制"}</span>
                    </button>
                </div>
                <pre><code>{visualPage.copyBlock.content}</code></pre>
            </section>}

            <section class="ai-section ai-reveal relative mb-9" style="animation-delay: calc(var(--content-delay) + 350ms);">
                <div class="grid md:grid-cols-[minmax(0,1fr)_17rem] gap-5">
                    <blockquote class="ai-quote px-5 py-5 md:px-6 md:py-6">
                        <Icon name="material-symbols:format-quote-rounded" class="text-[var(--primary)] text-4xl mb-2"></Icon>
                        <p class="text-2xl md:text-3xl leading-10 font-bold text-90 m-0">
                            {visualPage.quote}
                        </p>
                    </blockquote>

                    <div class="ai-signal-stack px-4 py-4">
                        <div class="text-90 font-bold mb-3">状态便签</div>
                        <div class="flex flex-col gap-3">
                            {visualPage.signals.map((signal) => (
                                <div>
                                    <div class="text-50 text-sm mb-1">{signal.label}</div>
                                    <div class="text-75 leading-6">{signal.value}</div>
                                </div>
                            ))}
                        </div>
                    </div>
                </div>
            </section>

            <section class="relative onload-animation" style="animation-delay: calc(var(--content-delay) + 400ms);">
                <div class="ai-closing px-5 py-5 md:px-6 md:py-6 flex flex-col md:flex-row md:items-center gap-4">
                    <div class="h-11 w-11 rounded-xl bg-[var(--btn-regular-bg)] text-[var(--primary)] flex items-center justify-center shrink-0">
                        <Icon name="material-symbols:auto-awesome-rounded" class="text-2xl"></Icon>
                    </div>
                    <p class="text-75 leading-8 m-0 flex-1">{visualPage.closing}</p>
                    <a href={getAiVisualPageUrl(visualPage.slug)} aria-current="page" class="btn-regular rounded-xl h-11 px-4 gap-2 font-bold shrink-0">
                        当前视图
                    </a>
                </div>
            </section>
        </article>
    </div>
</MainGridLayout>

<style>
    .ai-visual-page {
        container-type: inline-size;
        overflow-wrap: anywhere;
        word-break: break-word;
    }

    .ai-visual-page :where(p, div, h1, h2, h3, blockquote) {
        min-width: 0;
    }

    @media (max-width: 640px) {
        .ai-visual-page :where(p, div, h1, h2, h3, span) {
            line-break: anywhere;
            word-break: break-all;
        }
    }

    .ai-visual-wash {
        background:
            linear-gradient(180deg, oklch(0.96 0.035 var(--hue) / 0.72), transparent),
            repeating-linear-gradient(90deg, color-mix(in oklch, var(--primary) 10%, transparent) 0 1px, transparent 1px 5rem);
    }

    .ai-variant-game .ai-visual-wash {
        background:
            radial-gradient(circle at 78% 8%, color-mix(in oklch, var(--primary) 16%, transparent), transparent 18rem),
            linear-gradient(180deg, oklch(0.95 0.032 calc(var(--hue) + 12) / 0.7), transparent),
            repeating-linear-gradient(135deg, color-mix(in oklch, var(--primary) 9%, transparent) 0 1px, transparent 1px 4.2rem);
    }

    :root.dark .ai-visual-wash {
        background:
            linear-gradient(180deg, oklch(0.28 0.04 var(--hue) / 0.45), transparent),
            repeating-linear-gradient(90deg, color-mix(in oklch, var(--primary) 12%, transparent) 0 1px, transparent 1px 5rem);
    }

    .ai-hero-stage,
    .ai-feature-flow,
    .ai-awards,
    .ai-statboard,
    .ai-link-runway,
    .ai-detail-card,
    .ai-copy-panel,
    .ai-quote,
    .ai-signal-stack,
    .ai-closing {
        background: color-mix(in oklch, var(--btn-plain-bg-hover) 72%, transparent);
    }

    .ai-hero-stage,
    .ai-awards,
    .ai-statboard,
    .ai-link-runway,
    .ai-detail-card,
    .ai-copy-panel,
    .ai-quote,
    .ai-signal-stack,
    .ai-closing {
        border: 1px solid color-mix(in oklch, var(--primary) 18%, var(--line-divider));
    }

    .ai-reveal {
        opacity: 0;
        transform: translateY(0.9rem);
        transition: transform 480ms cubic-bezier(0.22, 1, 0.36, 1), opacity 360ms ease;
    }

    .ai-reveal.is-visible {
        opacity: 1;
        transform: translateY(0);
    }

    .ai-hero-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(11rem, 15rem);
        gap: 1.5rem;
        align-items: center;
    }

    .ai-variant-game .ai-hero-grid {
        grid-template-columns: minmax(0, 1fr) minmax(16.5rem, 18.5rem);
    }

    .ai-lead-line {
        max-width: 48rem;
    }

    .ai-metric-ribbon {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.75rem;
    }

    .ai-metric-token {
        position: relative;
        overflow: hidden;
        border-radius: 1.1rem;
        padding: 0.95rem 1rem;
        background: color-mix(in oklch, var(--card-bg) 54%, transparent);
    }

    .ai-metric-token::before {
        position: absolute;
        inset: 0 auto 0 0;
        width: 0.22rem;
        border-radius: inherit;
        background: var(--primary);
        content: "";
    }

    .ai-sound-orbit {
        justify-self: end;
        width: min(100%, 14rem);
    }

    .ai-sound-shell {
        position: relative;
        display: grid;
        place-items: center;
        min-height: 14rem;
        cursor: pointer;
        border-radius: 999px;
        background:
            linear-gradient(color-mix(in oklch, var(--card-bg) 78%, transparent), color-mix(in oklch, var(--btn-plain-bg-hover) 74%, transparent)) padding-box,
            conic-gradient(from 160deg, color-mix(in oklch, var(--primary) 72%, white), transparent 36%, color-mix(in oklch, var(--primary) 42%, black), transparent 74%, color-mix(in oklch, var(--primary) 72%, white)) border-box;
        border: 1px solid transparent;
        box-shadow: inset 0 0 0 0.75rem color-mix(in oklch, var(--card-bg) 36%, transparent);
    }

    .ai-audio-style-disc .ai-sound-shell::before,
    .ai-audio-style-disc .ai-sound-shell::after {
        position: absolute;
        border-radius: 999px;
        border: 1px dashed color-mix(in oklch, var(--primary) 22%, transparent);
        content: "";
        pointer-events: none;
    }

