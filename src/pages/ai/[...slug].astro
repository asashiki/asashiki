        line-height: 2rem;
    }

    .ai-award-focus-top small {
        color: color-mix(in oklch, currentColor 58%, transparent);
        font-weight: 800;
    }

    .ai-award-focus-kicker {
        margin-bottom: 0.5rem;
        color: var(--primary);
        font-size: 0.88rem;
        font-weight: 900;
        line-height: 1.4rem;
    }

    .ai-award-focus h3 {
        margin: 0;
        color: var(--text-regular);
        font-size: 1.35rem;
        font-weight: 900;
        line-height: 2rem;
    }

    .ai-award-focus p {
        margin: 0.9rem 0 0;
        color: color-mix(in oklch, currentColor 72%, transparent);
        line-height: 1.75rem;
    }

    .ai-award-dots {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.4rem;
        margin-top: 0.9rem;
    }

    .ai-award-dot {
        width: 2.1rem;
        height: 0.42rem;
        border-radius: 999px;
        background: color-mix(in oklch, currentColor 16%, transparent);
        transform: scaleX(0.58);
        transition: transform 180ms ease, background-color 180ms ease;
    }

