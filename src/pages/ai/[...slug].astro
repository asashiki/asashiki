        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
    }

    .ai-award-card-cue {
        position: absolute;
        right: 0.85rem;
        bottom: 0.85rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2rem;
        height: 2rem;
        border-radius: 999px;
        color: var(--primary);
        background: var(--card-bg);
        opacity: 0;
        transform: translateY(0.25rem) scale(0.96);
        transition: transform 180ms cubic-bezier(0.22, 1, 0.36, 1), opacity 160ms ease;
