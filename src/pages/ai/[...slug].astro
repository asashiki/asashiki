        margin-top: 0.85rem;
    }

    .ai-detail-card ul {
        display: grid;
        gap: 0.35rem;
        margin: 0.75rem 0 0;
        padding-left: 1rem;
        color: color-mix(in oklch, currentColor 68%, transparent);
        line-height: 1.6rem;
    }

    .ai-copy-panel {
        border-radius: 1.35rem;
        padding: 1rem;
    }

    .ai-copy-head {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: center;
        margin-bottom: 0.85rem;
    }

    .ai-copy-button {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        height: 2.45rem;
        border-radius: 999px;
        padding-inline: 0.9rem;
        color: var(--primary);
        background: var(--btn-regular-bg);
