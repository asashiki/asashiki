        background: var(--primary);
        transform: scaleX(1);
    }

    .ai-variant-game .ai-awards-stage {
        grid-template-columns: minmax(0, 0.86fr) minmax(16rem, 1fr);
    }

    .ai-variant-game .ai-award-page {
        grid-template-columns: 1fr;
    }

    .ai-variant-game .ai-award-card {
        min-height: 6.7rem;
        border-style: solid;
        border-radius: 1.1rem;
