        color: var(--primary);
        background: var(--btn-regular-bg);
        font-size: 0.78rem;
        font-weight: 800;
    }

    .ai-feature-switch strong {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .ai-feature-switch.is-active {
        color: var(--text-regular);
        background: color-mix(in oklch, var(--btn-regular-bg-hover) 62%, var(--card-bg));
    }

    .ai-feature-river {
