        overflow: hidden;
        border-radius: inherit;
        box-shadow: inset 0 0 0 0.26rem color-mix(in oklch, var(--card-bg) 88%, transparent);
    }

    .ai-sound-play {
        position: absolute;
        right: -0.15rem;
        bottom: -0.15rem;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 2.25rem;
        height: 2.25rem;
        border-radius: 999px;
        background: var(--card-bg);
        box-shadow: 0 0.45rem 1rem rgba(0, 0, 0, 0.14);
    }

    .ai-sound-copy {
        align-self: center;
        min-width: 0;
        text-align: left;
    }

    .ai-sound-bars {
        position: absolute;
        top: 1.1rem;
        display: flex;
        gap: 0.18rem;
        align-items: end;
        height: 1rem;
        pointer-events: none;
    }

    .ai-sound-bars span {
        width: 0.18rem;
        height: 0.45rem;
        border-radius: 999px;
        background: var(--primary);
        opacity: 0.55;
    }

    .ai-audio-style-save .ai-sound-button {
        width: 4.75rem;
        height: 4.75rem;
    }

    .ai-audio-style-save .ai-sound-bars {
        position: static;
        align-self: center;
        justify-self: end;
    }

    .ai-audio-style-save .ai-sound-copy > * {
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .ai-audio-style-save .ai-sound-copy > :nth-child(2) {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
    }

    .ai-sound-bars span:nth-child(2) {
        height: 0.9rem;
    }

    .ai-sound-bars span:nth-child(3) {
        height: 0.65rem;
    }

    .ai-sound-orbit.is-playing .ai-sound-cover {
        animation: ai-disc-spin 8s linear infinite;
    }

    .ai-sound-orbit.is-playing .ai-sound-bars span {
        animation: ai-eq 780ms ease-in-out infinite alternate;
    }

    .ai-sound-orbit.is-playing .ai-sound-bars span:nth-child(2) {
        animation-delay: 120ms;
    }

    .ai-sound-orbit.is-playing .ai-sound-bars span:nth-child(3) {
        animation-delay: 240ms;
    }

    .ai-sound-orbit.is-playing .ai-sound-bars span:nth-child(4) {
        animation-delay: 360ms;
    }

    .ai-section-heading {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 1rem;
    }

    .ai-statboard {
        border-radius: 1.35rem;
        padding: 1rem;
    }

    .ai-stat-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.8rem;
    }

    .ai-stat-bar {
        display: grid;
        gap: 0.65rem;
        min-width: 0;
        border-radius: 1.1rem;
        padding: 0.95rem;
        text-align: left;
        background: color-mix(in oklch, var(--card-bg) 48%, transparent);
        border: 1px dashed var(--line-divider);
        transition: transform 220ms cubic-bezier(0.22, 1, 0.36, 1), background-color 180ms ease, border-color 180ms ease;
    }

    .ai-stat-top {
        display: flex;
        justify-content: space-between;
        gap: 0.75rem;
        color: color-mix(in oklch, currentColor 58%, transparent);
        font-size: 0.86rem;
    }

    .ai-stat-top strong {
        color: var(--primary);
        font-size: 1.15rem;
    }

    .ai-stat-track {
        display: block;
        height: 0.55rem;
        overflow: hidden;
        border-radius: 999px;
        background: color-mix(in oklch, currentColor 10%, transparent);
    }

    .ai-stat-track span {
        display: block;
        width: calc(var(--stat-ratio) * 100%);
        height: 100%;
        border-radius: inherit;
        background: linear-gradient(90deg, var(--primary), color-mix(in oklch, var(--primary) 70%, white));
        transform-origin: left center;
        transform: scaleX(0.92);
        transition: transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    .ai-stat-detail {
        color: color-mix(in oklch, currentColor 58%, transparent);
        font-size: 0.82rem;
        line-height: 1.35rem;
    }

    .ai-stat-bar.is-active {
        background: color-mix(in oklch, var(--btn-regular-bg-hover) 56%, var(--card-bg));
        border-color: color-mix(in oklch, var(--primary) 30%, var(--line-divider));
    }

    .ai-stat-bar.is-active .ai-stat-track span {
        transform: scaleX(1);
    }

    .ai-feature-board {
        display: grid;
        grid-template-columns: minmax(10rem, 15rem) minmax(0, 1fr);
        gap: 1rem;
        align-items: stretch;
    }

    .ai-feature-switches {
        display: grid;
        gap: 0.5rem;
        align-content: start;
    }

    .ai-feature-switch {
        display: grid;
        grid-template-columns: 2.25rem minmax(0, 1fr);
        gap: 0.6rem;
        align-items: center;
        border-radius: 1rem;
        padding: 0.7rem 0.75rem;
        color: color-mix(in oklch, currentColor 62%, transparent);
        background: color-mix(in oklch, var(--card-bg) 36%, transparent);
        text-align: left;
        transition: transform 200ms cubic-bezier(0.22, 1, 0.36, 1), background-color 180ms ease, color 180ms ease;
