        display: grid;
        min-height: 13rem;
    }

    .ai-feature-flow {
        display: grid;
        grid-area: 1 / 1;
        grid-template-columns: 3rem minmax(0, 1fr) auto;
        gap: 1rem;
        align-items: center;
        border-radius: 1.25rem;
        padding: 1.05rem 1.1rem;
        border: 1px dashed var(--line-divider);
        opacity: 0;
