---
---

<div id="global-audio-player" class="global-audio-player hidden" aria-live="polite">
    <div class="global-audio-shell">
        <button class="global-audio-cover" type="button" aria-label="播放或暂停音乐">
            <img alt="" />
            <span class="global-audio-cover-dot"></span>
        </button>

        <div class="global-audio-body">
            <div class="global-audio-title"></div>
            <div class="global-audio-artist"></div>
            <button class="global-audio-progress" type="button" aria-label="跳转播放进度">
                <span></span>
            </button>
            <div class="global-audio-lyric"></div>
        </div>

        <div class="global-audio-actions">
            <button class="global-audio-toggle" type="button" aria-label="播放或暂停">
                <span class="global-audio-toggle-play">▶</span>
                <span class="global-audio-toggle-pause hidden">Ⅱ</span>
            </button>
            <button class="global-audio-close" type="button" aria-label="关闭播放器">×</button>
        </div>
    </div>

    <audio preload="metadata" crossorigin="anonymous"></audio>
</div>

<style>
    .global-audio-player {
        position: fixed;
        right: 1rem;
        bottom: 1rem;
        z-index: 80;
        width: min(23rem, calc(100vw - 2rem));
        padding: 0.62rem;
        border: 1px solid color-mix(in oklch, var(--primary) 24%, transparent);
        border-radius: 1.25rem;
        color: rgba(0, 0, 0, 0.82);
        background:
            radial-gradient(circle at 0% 0%, color-mix(in oklch, var(--primary) 14%, transparent), transparent 42%),
            color-mix(in oklch, var(--card-bg) 92%, transparent);
        box-shadow: 0 0.9rem 2.4rem rgba(0, 0, 0, 0.13);
        backdrop-filter: blur(18px);
        transform-origin: calc(100% - 2.5rem) 100%;
        transition: transform 220ms cubic-bezier(0.22, 1, 0.36, 1), opacity 200ms ease, border-color 180ms ease;
    }

    .global-audio-player.hidden {
        display: block !important;
        opacity: 0;
        pointer-events: none;
        transform: translateY(0.75rem) scale(0.98);
    }

    :root.dark .global-audio-player {
        color: rgba(255, 255, 255, 0.86);
    }

    .global-audio-shell {
        display: grid;
        grid-template-columns: 3.2rem minmax(0, 1fr) auto;
        align-items: center;
        gap: 0.7rem;
    }

    .global-audio-cover {
        position: relative;
        width: 3.2rem;
        height: 3.2rem;
        overflow: hidden;
        border-radius: 50%;
        background: var(--btn-regular-bg);
        box-shadow: inset 0 0 0 0.24rem color-mix(in oklch, var(--card-bg) 86%, transparent);
        transition: transform 180ms cubic-bezier(0.22, 1, 0.36, 1), box-shadow 180ms ease;
    }

    .global-audio-cover img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .global-audio-cover-dot {
        position: absolute;
        inset: 50% auto auto 50%;
        width: 0.5rem;
        height: 0.5rem;
        border-radius: 999px;
        background: color-mix(in oklch, var(--card-bg) 92%, white);
        box-shadow: 0 0 0 0.2rem color-mix(in oklch, var(--primary) 20%, transparent);
        transform: translate(-50%, -50%);
    }

    .global-audio-player.is-playing .global-audio-cover {
        animation: global-audio-spin 9s linear infinite;
    }

    .global-audio-body {
        min-width: 0;
    }

    .global-audio-artist,
    .global-audio-lyric {
        overflow: hidden;
        color: color-mix(in oklch, currentColor 48%, transparent);
        font-size: 0.72rem;
        line-height: 0.95rem;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .global-audio-title {
        overflow: hidden;
        color: rgba(0, 0, 0, 0.9);
        font-weight: 800;
        line-height: 1.35rem;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    :root.dark .global-audio-title {
        color: rgba(255, 255, 255, 0.92);
    }

    .global-audio-progress {
        width: 100%;
        height: 0.38rem;
        margin-top: 0.36rem;
        overflow: hidden;
        border-radius: 999px;
        background: color-mix(in oklch, var(--btn-regular-bg) 86%, transparent);
    }

    .global-audio-progress span {
        display: block;
        width: 0%;
        height: 100%;
        border-radius: inherit;
        background: linear-gradient(90deg, var(--primary), color-mix(in oklch, var(--primary) 72%, white));
        transition: width 150ms linear;
    }

    .global-audio-lyric {
        margin-top: 0.16rem;
        color: color-mix(in oklch, var(--primary) 68%, currentColor);
        font-weight: 600;
    }

    .global-audio-actions {
        display: flex;
        flex-direction: column;
        gap: 0.32rem;
    }

    .global-audio-toggle,
    .global-audio-close {
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        color: var(--primary);
        background: var(--btn-regular-bg);
        transition: transform 180ms cubic-bezier(0.22, 1, 0.36, 1), background-color 180ms ease;
    }

    .global-audio-toggle {
        width: 2.2rem;
        height: 2.2rem;
        font-weight: 800;
    }

    .global-audio-close {
        width: 2.2rem;
        height: 1.45rem;
        color: color-mix(in oklch, currentColor 45%, transparent);
    }

    @media (hover: hover) and (pointer: fine) {
        .global-audio-toggle:hover,
        .global-audio-close:hover,
        .global-audio-cover:hover,
        .global-audio-progress:hover {
            transform: translateY(-1px);
            background: var(--btn-regular-bg-hover);
        }

        .global-audio-cover:hover {
            box-shadow:
                inset 0 0 0 0.24rem color-mix(in oklch, var(--card-bg) 86%, transparent),
                0 0.45rem 1rem color-mix(in oklch, var(--primary) 18%, transparent);
        }
    }

    @media (max-width: 640px) {
        .global-audio-player {
            right: 0.75rem;
            bottom: 0.75rem;
            width: calc(100vw - 1.5rem);
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .global-audio-player,
        .global-audio-toggle,
        .global-audio-close,
        .global-audio-cover,
        .global-audio-progress span {
            transition: none;
        }

        .global-audio-player.is-playing .global-audio-cover {
            animation: none;
        }
    }

    @keyframes global-audio-spin {
        from {
            transform: rotate(0deg);
        }
        to {
            transform: rotate(360deg);
        }
    }
</style>

<script>
import {
	getLyricByUrl,
	getMetingSong,
	getMetingSongUrl,
	parseLRC,
	type ParsedLrcLine,
} from "@utils/music-api";

type AudioState = "loading" | "playing" | "paused" | "ended" | "error";

type AudioDetail = {
	provider?: "audio" | "meting" | "netease";
	src?: string;
	metingId?: string;
	songId?: string;
	neteaseId?: string;
	server?: string;
	title?: string;
	artist?: string;
	cover?: string;
};

const player = document.getElementById("global-audio-player");
if (player instanceof HTMLElement && !player.dataset.bound) {
	const playerEl = player;
	playerEl.dataset.bound = "true";

	const audio = playerEl.querySelector("audio");
	const cover = playerEl.querySelector(".global-audio-cover img");
	const title = playerEl.querySelector(".global-audio-title");
	const artist = playerEl.querySelector(".global-audio-artist");
	const lyric = playerEl.querySelector(".global-audio-lyric");
	const progress = playerEl.querySelector(".global-audio-progress span");
	const progressButton = playerEl.querySelector(".global-audio-progress");
	const toggle = playerEl.querySelector(".global-audio-toggle");
	const close = playerEl.querySelector(".global-audio-close");
	const coverButton = playerEl.querySelector(".global-audio-cover");
	const playIcon = playerEl.querySelector(".global-audio-toggle-play");
	const pauseIcon = playerEl.querySelector(".global-audio-toggle-pause");

	let currentProvider: "audio" | "meting" | "" = "";
	let currentSongKey = "";
	let currentState: AudioState | "idle" = "idle";
	let progressTimer = 0;
	let lyricLines: ParsedLrcLine[] = [];
	let activeLyricIndex = -1;

	function getMetingId(detail: AudioDetail) {
		return detail.metingId || detail.songId || detail.neteaseId || "";
	}

	function getButtonSongKey(button: HTMLElement) {
		const metingId = button.dataset.metingId || "";
		const src = button.dataset.audioSrc || "";
		if (metingId) return `${button.dataset.metingServer || "netease"}:${metingId}`;
		return src;
	}

	function setInlineAudioState(state: AudioState | "idle") {
		document.querySelectorAll(".ai-audio-toggle").forEach((button) => {
			if (!(button instanceof HTMLElement)) return;
			const buttonKey = getButtonSongKey(button);
			const isCurrent = !!buttonKey && !!currentSongKey && buttonKey === currentSongKey;
			const visibleState = isCurrent ? state : "idle";

			const shell = button.closest(".ai-audio-chip");
			const label = button.querySelector(".ai-audio-label");
			const inlinePlayIcon = button.querySelector(".ai-audio-play");
			const inlinePauseIcon = button.querySelector(".ai-audio-pause");
			const inlineLoadingIcon = button.querySelector(".ai-audio-loading");

			shell?.classList.toggle(
				"is-playing",
				visibleState === "playing" || visibleState === "loading",
			);
			shell?.classList.toggle("needs-audio", visibleState === "error");
			button.setAttribute("aria-busy", String(visibleState === "loading"));

			if (label) {
				if (visibleState === "loading") label.textContent = "载入";
				else if (visibleState === "playing") label.textContent = "播放中";
				else if (visibleState === "paused") label.textContent = "继续";
				else if (visibleState === "ended") label.textContent = "重播";
				else if (visibleState === "error") label.textContent = "失败";
				else label.textContent = button.dataset.hasAudio === "true" ? "播放" : "待配置";
			}

			inlinePlayIcon?.classList.toggle(
				"hidden",
				visibleState === "playing" || visibleState === "loading",
			);
			inlinePauseIcon?.classList.toggle("hidden", visibleState !== "playing");
			inlineLoadingIcon?.classList.toggle("hidden", visibleState !== "loading");
		});
	}

	function emitState(state: AudioState) {
		currentState = state;
		setInlineAudioState(state);
		document.dispatchEvent(
			new CustomEvent("ai-visual-audio:state", {
				detail: { state, key: currentSongKey },
			}),
		);
	}

	function syncInlineAudioState() {
		setInlineAudioState(currentState);
	}

	function setText(element: Element | null, value: string) {
		if (element) element.textContent = value;
	}

	function setPlaying(isPlaying: boolean) {
		playerEl.classList.toggle("is-playing", isPlaying);
		playIcon?.classList.toggle("hidden", isPlaying);
		pauseIcon?.classList.toggle("hidden", !isPlaying);
		emitState(isPlaying ? "playing" : "paused");
	}

	function setProgress(percent: number) {
		if (progress instanceof HTMLElement) {
			progress.style.width = `${Math.max(0, Math.min(100, percent))}%`;
		}
	}

	function stopProgressTimer() {
		if (progressTimer) {
			window.clearInterval(progressTimer);
			progressTimer = 0;
		}
	}

	function updateProgress() {
		if (!(audio instanceof HTMLAudioElement) || audio.duration <= 0) return;
		setProgress((audio.currentTime / audio.duration) * 100);
		updateLyric(audio.currentTime);
	}

	function startProgressTimer() {
		stopProgressTimer();
		updateProgress();
		progressTimer = window.setInterval(updateProgress, 500);
	}

	function setMetadata(detail: AudioDetail) {
		if (cover instanceof HTMLImageElement) cover.src = detail.cover || "";
		setText(title, detail.title || "Untitled");
		setText(artist, detail.artist || "");
	}

	function resetLyric() {
		lyricLines = [];
		activeLyricIndex = -1;
		setText(lyric, "");
	}

	function updateLyric(currentTime: number) {
		if (!lyricLines.length) return;

		let nextIndex = -1;
		for (let index = 0; index < lyricLines.length; index += 1) {
			if (lyricLines[index].time <= currentTime + 0.2) nextIndex = index;
			else break;
		}

		if (nextIndex !== activeLyricIndex) {
			activeLyricIndex = nextIndex;
			setText(lyric, lyricLines[nextIndex]?.text || "");
		}
	}

	async function loadLyric(lrcUrl: string) {
		resetLyric();
		if (!lrcUrl) return;

		try {
			const lrcText = await getLyricByUrl(lrcUrl);
			lyricLines = parseLRC(lrcText);
			updateProgress();
		} catch {
			resetLyric();
		}
	}

	async function playAudio(detail: AudioDetail) {
		if (!(audio instanceof HTMLAudioElement) || !detail.src) return;

		currentProvider = detail.provider === "meting" || detail.provider === "netease" ? "meting" : "audio";
		playerEl.classList.remove("hidden");
		setMetadata(detail);

		if (audio.src !== detail.src) {
			audio.src = detail.src;
			setProgress(0);
			resetLyric();
		}

		try {
			await audio.play();
			setPlaying(true);
			startProgressTimer();
		} catch {
			setPlaying(false);
			emitState("error");
			stopProgressTimer();
		}
	}

	async function enrichMetingMetadata(detail: AudioDetail, metingId: string, server: string) {
		try {
			const song = await getMetingSong(metingId, server);
			if (!song) return;

			setMetadata({
				...detail,
				provider: "meting",
				title: song.name || detail.title,
				artist: song.artists || detail.artist,
				cover: song.cover || detail.cover,
			});
			await loadLyric(song.lrc);
		} catch {
			// The audio URL is already playing; metadata failure should not stop playback.
		}
	}

	async function playMeting(detail: AudioDetail) {
		if (!(audio instanceof HTMLAudioElement)) return;

		const metingId = getMetingId(detail);
		const server = detail.server || "netease";
		if (!metingId) {
			emitState("error");
			return;
		}

		const nextSongKey = `${server}:${metingId}`;
		if (currentProvider === "meting" && currentSongKey === nextSongKey && audio.src) {
			await togglePlayback();
			return;
		}

		currentSongKey = nextSongKey;
		currentProvider = "meting";
		emitState("loading");

		const directUrl = detail.src || getMetingSongUrl(metingId, server);
		await playAudio({
			...detail,
			provider: "meting",
			src: directUrl,
			title: detail.title || "正在播放",
			artist: detail.artist || "",
		});

		enrichMetingMetadata(detail, metingId, server);
	}

	async function togglePlayback() {
		if (!(audio instanceof HTMLAudioElement) || !audio.src) return;

		if (audio.paused) {
			try {
				await audio.play();
				setPlaying(true);
				startProgressTimer();
			} catch {
				emitState("error");
			}
		} else {
			audio.pause();
			setPlaying(false);
			stopProgressTimer();
		}
	}

	function detailFromButton(button: HTMLElement): AudioDetail {
		return {
			provider: (button.dataset.audioProvider || "audio") as AudioDetail["provider"],
			src: button.dataset.audioSrc || "",
			metingId: button.dataset.metingId || "",
			server: button.dataset.metingServer || "netease",
			title: button.dataset.audioTitle || "",
			artist: button.dataset.audioArtist || "",
			cover: button.dataset.audioCover || "",
		};
	}

	document.addEventListener(
		"click",
		async (event) => {
			const target = event.target;
			if (!(target instanceof Element)) return;

			const button =
				target.closest(".ai-audio-toggle") ||
				target.closest(".ai-audio-chip")?.querySelector(".ai-audio-toggle");
			if (!(button instanceof HTMLElement)) return;

			event.preventDefault();
			const detail = detailFromButton(button);
			const metingId = getMetingId(detail);
			if (!detail.src && !metingId) {
				currentSongKey = getButtonSongKey(button);
				emitState("error");
				return;
			}

			if (metingId || detail.provider === "meting" || detail.provider === "netease") {
				await playMeting(detail);
			} else {
				currentSongKey = detail.src || "";
				await playAudio(detail);
			}
		},
		{ capture: true },
	);

	document.addEventListener("ai-visual-audio:play", async (event) => {
		const detail = ((event as CustomEvent<AudioDetail>).detail || {}) as AudioDetail;
		if (detail.provider === "meting" || detail.provider === "netease" || getMetingId(detail)) {
			await playMeting(detail);
		} else {
			currentSongKey = detail.src || "";
			await playAudio(detail);
		}
	});

	document.addEventListener("ai-visual-audio:sync", syncInlineAudioState);

	const setupRouteSync = () => {
		window.swup?.hooks?.on("page:view", syncInlineAudioState);
		window.swup?.hooks?.on("content:replace", syncInlineAudioState);
	};

	if (window.swup?.hooks) {
		setupRouteSync();
	} else {
		document.addEventListener("swup:enable", setupRouteSync);
	}

	toggle?.addEventListener("click", togglePlayback);
	coverButton?.addEventListener("click", togglePlayback);

	close?.addEventListener("click", () => {
		if (audio instanceof HTMLAudioElement) {
			audio.pause();
			audio.currentTime = 0;
		}
		currentProvider = "";
		currentSongKey = "";
		currentState = "idle";
		stopProgressTimer();
		setProgress(0);
		setInlineAudioState("idle");
		playerEl.classList.remove("is-playing");
		playIcon?.classList.remove("hidden");
		pauseIcon?.classList.add("hidden");
		resetLyric();
		playerEl.classList.add("hidden");
	});

	progressButton?.addEventListener("click", (event) => {
		if (!(event instanceof MouseEvent) || !(progressButton instanceof HTMLElement)) return;
		if (!(audio instanceof HTMLAudioElement) || audio.duration <= 0) return;

		const rect = progressButton.getBoundingClientRect();
		const ratio = Math.max(0, Math.min(1, (event.clientX - rect.left) / rect.width));
		audio.currentTime = audio.duration * ratio;
		setProgress(ratio * 100);
		updateLyric(audio.currentTime);
	});

	audio?.addEventListener("pause", () => {
		if (currentProvider) {
			setPlaying(false);
			stopProgressTimer();
		}
	});
	audio?.addEventListener("play", () => {
		if (currentProvider) {
			setPlaying(true);
			startProgressTimer();
		}
	});
	audio?.addEventListener("ended", () => {
		if (currentProvider) {
			setPlaying(false);
			stopProgressTimer();
			setProgress(100);
			emitState("ended");
		}
	});
	audio?.addEventListener("error", () => {
		setPlaying(false);
		stopProgressTimer();
		emitState("error");
	});
	audio?.addEventListener("timeupdate", updateProgress);
}
</script>
