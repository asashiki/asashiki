---
type HeatmapDay = {
  date: string;
  count: number;
};

interface Props {
  days: HeatmapDay[];
}

const { days } = Astro.props;

function levelFor(count: number) {
  if (count >= 15) return 4;
  if (count >= 10) return 3;
  if (count >= 5) return 2;
  if (count > 0) return 1;
  return 0;
}

function dateLabel(date: string) {
  return new Intl.DateTimeFormat("zh-CN", {
    day: "2-digit",
    month: "2-digit",
    timeZone: "Asia/Shanghai",
  }).format(new Date(`${date}T00:00:00+08:00`));
}

const monthNames = ["1月", "2月", "3月", "4月", "5月", "6月", "7月", "8月", "9月", "10月", "11月", "12月"];
const firstDay = days[0] ? new Date(`${days[0].date}T00:00:00+08:00`) : null;
const startOffset = firstDay?.getDay() || 0;
const cells = days.map((day, index) => {
  const date = new Date(`${day.date}T00:00:00+08:00`);
  return {
    ...day,
    dayIndex: date.getDay() + 2,
    label: dateLabel(day.date),
    level: levelFor(day.count),
    month: date.getMonth(),
    weekIndex: Math.floor((index + startOffset) / 7) + 2,
  };
});
const monthLabels = cells.filter((cell, index) => {
  if (cell.dayIndex !== 2) return false;
  const previous = cells[index - 7];
  return !previous || previous.month !== cell.month;
});
const hasActivity = days.some((day) => day.count > 0);
const total = days.reduce((sum, day) => sum + day.count, 0);
const rangeLabel = days.length ? `${dateLabel(days[0].date)} - ${dateLabel(days[days.length - 1].date)}` : "";
---

{hasActivity && (
  <section class="bangumi-heatmap" aria-labelledby="bangumi-heatmap-title">
    <div class="bangumi-heatmap-head">
      <h2 id="bangumi-heatmap-title">追番活跃</h2>
      <span>{rangeLabel}</span>
    </div>
    <div class="bangumi-heatmap-scroll">
      <div class="bangumi-heatmap-grid">
        {monthLabels.map((month) => (
          <span
            class="bangumi-heatmap-month"
            style={`grid-column: ${month.weekIndex};`}
          >
            {monthNames[month.month]}
          </span>
        ))}
        <span class="bangumi-heatmap-week" style="grid-row: 3;">一</span>
        <span class="bangumi-heatmap-week" style="grid-row: 5;">三</span>
        <span class="bangumi-heatmap-week" style="grid-row: 7;">五</span>
        {cells.map((day) => (
          <span
            class="bangumi-heatmap-cell"
            data-level={day.level}
            style={`grid-column: ${day.weekIndex}; grid-row: ${day.dayIndex};`}
            title={`${day.label} · ${day.count} 次活动`}
          />
        ))}
      </div>
    </div>
    <div class="bangumi-heatmap-legend" aria-hidden="true">
      <strong>过去一年 {total} 次</strong>
      <span>less</span>
      <i data-level="0"></i>
      <i data-level="1"></i>
      <i data-level="2"></i>
      <i data-level="3"></i>
      <i data-level="4"></i>
      <span>more</span>
    </div>
  </section>
)}

<style>
  .bangumi-heatmap {
    margin: 0 0 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--line-divider);
  }

  .bangumi-heatmap-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.7rem;
  }

  .bangumi-heatmap h2 {
    margin: 0;
    color: var(--btn-content);
    font-size: 0.9rem;
    font-weight: 650;
    line-height: 1.2;
  }

  .bangumi-heatmap-head span {
    color: color-mix(in oklch, var(--btn-content) 58%, var(--card-bg));
    font-size: 0.72rem;
    font-weight: 600;
    line-height: 1.2;
  }

  .bangumi-heatmap-scroll {
    max-width: 100%;
    overflow-x: auto;
    overflow-y: hidden;
    padding-bottom: 0.5rem;
    scrollbar-width: thin;
    scrollbar-color: color-mix(in oklch, var(--primary) 36%, transparent) transparent;
  }

  .bangumi-heatmap-scroll::-webkit-scrollbar {
    width: 0.34rem;
    height: 0.34rem;
  }

  .bangumi-heatmap-scroll::-webkit-scrollbar-track {
    background: transparent;
  }

  .bangumi-heatmap-scroll::-webkit-scrollbar-thumb {
    border-radius: 999px;
    background: color-mix(in oklch, var(--primary) 34%, transparent);
  }

  .bangumi-heatmap-scroll::-webkit-scrollbar-thumb:hover {
    background: color-mix(in oklch, var(--primary) 48%, transparent);
  }

  .bangumi-heatmap-scroll::-webkit-scrollbar-thumb:active {
    background: color-mix(in oklch, var(--primary) 62%, transparent);
  }

  .bangumi-heatmap-grid {
    display: grid;
    grid-template-rows: 1rem repeat(7, 0.72rem);
    grid-auto-columns: 0.72rem;
    gap: 0.22rem;
    width: max-content;
    min-height: calc(1rem + 7 * 0.72rem + 7 * 0.22rem);
    padding-left: 1.2rem;
  }

  .bangumi-heatmap-cell,
  .bangumi-heatmap-legend i {
    display: block;
    width: 0.72rem;
    height: 0.72rem;
    border-radius: 0.18rem;
    background: var(--btn-regular-bg);
    box-shadow: inset 0 0 0 1px color-mix(in oklch, var(--line-divider) 80%, transparent);
  }

  .bangumi-heatmap-month,
  .bangumi-heatmap-week {
    color: color-mix(in oklch, var(--btn-content) 58%, var(--card-bg));
    font-size: 0.66rem;
    font-weight: 600;
    line-height: 0.72rem;
    white-space: nowrap;
  }

  .bangumi-heatmap-month {
    grid-row: 1;
  }

  .bangumi-heatmap-week {
    grid-column: 1;
    justify-self: end;
  }

  .bangumi-heatmap-cell[data-level="1"],
  .bangumi-heatmap-legend i[data-level="1"] {
    background: color-mix(in oklch, var(--primary) 25%, var(--card-bg));
  }

  .bangumi-heatmap-cell[data-level="2"],
  .bangumi-heatmap-legend i[data-level="2"] {
    background: color-mix(in oklch, var(--primary) 45%, var(--card-bg));
  }

  .bangumi-heatmap-cell[data-level="3"],
  .bangumi-heatmap-legend i[data-level="3"] {
    background: color-mix(in oklch, var(--primary) 70%, var(--card-bg));
  }

  .bangumi-heatmap-cell[data-level="4"],
  .bangumi-heatmap-legend i[data-level="4"] {
    background: color-mix(in oklch, var(--primary) 90%, var(--card-bg));
  }

  .bangumi-heatmap-legend {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.28rem;
    margin-top: 0.45rem;
    color: color-mix(in oklch, var(--btn-content) 62%, var(--card-bg));
    font-size: 0.68rem;
    line-height: 1;
  }

  .bangumi-heatmap-legend strong {
    margin-right: auto;
    color: color-mix(in oklch, var(--btn-content) 70%, var(--card-bg));
    font-weight: 650;
  }
</style>
